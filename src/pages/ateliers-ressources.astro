---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { workshops } from "../data/cmsContent.js";
import { archivedBlogArticles, featuredBlogArticles } from "../data/blogArticles.js";

const featuredWorkshop = workshops.find((workshop) => workshop.featured) ?? workshops[0];
const secondaryWorkshops = workshops.filter((workshop) => workshop !== featuredWorkshop).slice(0, 2);
const miniWorkshops = workshops.filter((workshop) => workshop !== featuredWorkshop).slice(2, 4);
const journalArticles = featuredBlogArticles.slice(0, 3);
const archivedArticles = archivedBlogArticles.slice(0, 4);
const archivedEvents = [
  {
    date: "Mai 2026",
    title: "Atelier douleurs de dos · matinée mobilité",
    tag: "Mobilité · Événement",
  },
  {
    date: "Avr. 2026",
    title: "Soirée respiration & lâcher-prise",
    tag: "Stress · Événement",
  },
];
---

<BaseLayout
  title="Ateliers & ressources - KerFlow Clamart"
  description="Ateliers, conférences, soirées, week-ends thématiques, articles et gazette KerFlow autour du sommeil, du stress, de l'alimentation, de la mobilité et des accompagnements & soins."
>
  <SiteHeader />
  <main class="workshops-page page svc-ateliers wrapped-sections">
    <section class="workshops-hero" data-screen-label="Ateliers - Hero">
      <div class="workshops-wrap">
        <div class="page-hero-grid">
          <div>
            <p class="kicker">La vie de la maison</p>
            <h1 class="serif">
              Les prochains<br />
              <i class="h-accent">rendez-vous</i><br />
              KerFlow.
            </h1>
            <div class="hero-cta">
              <a href="#agenda" class="btn btn-primary">
                Voir l'agenda
                <svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 12h16M14 6l6 6-6 6"></path></svg>
              </a>
              <a href="#newsletter" class="btn-line">Recevoir la Gazette</a>
            </div>
          </div>
          <aside class="page-hero-aside">
            <img class="workshops-hero-logo" src="/assets/logos/kerflow-atelier-web.png" width="1200" height="831" alt="KerFlow Atelier" loading="eager" decoding="async" />
            <p class="lede">
              Ateliers, conférences, rencontres et ressources : des formats complémentaires aux cours et aux accompagnements
              pour explorer un sujet, découvrir une pratique, approfondir ses connaissances ou simplement prendre le temps d'échanger.
              Tout au long de l'année, KerFlow accueille des intervenants, propose des événements ponctuels et partage sa Gazette pour prolonger la réflexion bien au-delà des murs de la maison.
            </p>
          </aside>
        </div>
      </div>
    </section>

    <section class="planning planning-cards section-pad events-planning" id="agenda" data-screen-label="Événements">
      <div class="workshops-wrap">
        <div class="planning-cards-head">
          <div>
            <p class="eyebrow">01 - Événements à venir</p>
            <h2>Au-delà<br /><em>des cours.</em></h2>
          </div>
          <div>
            <p>
              Ateliers pratiques, rencontres, conférences ou expériences ponctuelles : chaque événement possède son propre format
              et ses modalités d'inscription. Les réservations se font soit sur HelloResa, soit directement auprès de l'intervenant.
              Les places étant souvent limitées, nous vous conseillons de réserver à l'avance.
            </p>
          </div>
        </div>

        <div class="course-feature-grid">
          {featuredWorkshop && (
            <article class="course-card course-card-feature" data-event-topic={featuredWorkshop.title}>
              <div class="course-card-copy">
                <p class="course-kicker">↘ À la une ce mois-ci</p>
                <h3>{featuredWorkshop.title}<br /><em>{featuredWorkshop.date}</em></h3>
                <p>{featuredWorkshop.time} · {featuredWorkshop.duration} · {featuredWorkshop.description}</p>
                <footer>
                  <a href={featuredWorkshop.ctaUrl}>{featuredWorkshop.ctaLabel} →</a>
                </footer>
              </div>
              <div class={`photo ${featuredWorkshop.imageClass}`}><span>{featuredWorkshop.imageLabel}</span></div>
            </article>
          )}

          {secondaryWorkshops.map((workshop) => (
            <article class="course-card course-card-photo" data-event-topic={workshop.title}>
              <div class={`photo ${workshop.imageClass}`}><span>{workshop.imageLabel}</span></div>
              <div class="course-card-copy">
                <p class="course-kicker">{workshop.date} · {workshop.time}</p>
                <h4>{workshop.title}</h4>
                <p>{workshop.duration} · {workshop.price} · {workshop.description}</p>
                <footer>
                  <a href={workshop.ctaUrl}>{workshop.ctaLabel} →</a>
                </footer>
              </div>
            </article>
          ))}
        </div>

        <div class="course-mini-grid events-mini-grid" aria-label="Autres événements à venir">
          {miniWorkshops.map((workshop) => (
            <article data-event-topic={workshop.title}>
              <p>{workshop.date} · {workshop.time}</p>
              <h4>{workshop.title}</h4>
              <a href={workshop.ctaUrl}>{workshop.ctaLabel} →</a>
            </article>
          ))}
        </div>

      </div>
    </section>

    <section class="section-pad rule-top" data-screen-label="Journal">
      <div class="workshops-wrap">
        <div class="journal-head">
          <div class="sec-head compact">
            <span class="sec-num">02 - Les articles KerFlow</span>
            <h2 class="title">À lire et <i class="h c-petrol">à découvrir.</i></h2>
          </div>
          <p>
            Des articles pour partager des idées, des découvertes, des retours d'expérience et des sujets qui nous tiennent à cœur. À lire selon ses envies et sa curiosité du moment.
          </p>
        </div>

        <div class="articles">
          {journalArticles.map((article) => (
            <a href={`/blog/${article.slug}/`} class="art">
              <div class={`ph ${article.imageClass} ${article.visualMode === "image" && article.image ? "has-upload" : ""}`}>
                {article.visualMode === "image" && article.image ? (
                  <img src={article.image} alt={article.imageLabel} loading="lazy" decoding="async" />
                ) : (
                  <span class="cap">{article.imageLabel}</span>
                )}
              </div>
              <div class="a-body">
                <span class="a-tag">{article.tag}</span>
                <h3 class="serif">{article.title}</h3>
                <p>{article.excerpt}</p>
                <span class="a-foot">Lecture · {article.readingTime}</span>
              </div>
            </a>
          ))}
        </div>

        <div class="archive-link">
          <a href="/blog/" class="btn-line">
            Tous les articles
            <svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 12h16M14 6l6 6-6 6"></path></svg>
          </a>
        </div>
      </div>
    </section>

    <section class="section-pad rule-top band-paper" id="archives" data-screen-label="Archives">
      <div class="workshops-wrap">
        <div class="journal-head">
          <div class="sec-head compact">
            <span class="sec-num">03 - Archives</span>
            <h2 class="title">À retrouver<br /><i class="h c-petrol">plus tard.</i></h2>
          </div>
          <p>
            Une archive simple pour garder une trace des articles et des rendez-vous passés,
            sans créer de pages détail ni de classement complexe.
          </p>
        </div>

        <div class="archive-grid">
          <section class="archive-panel" aria-labelledby="archive-articles-title">
            <h3 id="archive-articles-title" class="serif">Articles passés</h3>
            <div class="list-rows">
              {archivedArticles.map((article) => (
                <a href={`/blog/${article.slug}/`} class="list-row">
                  <span class="lr-date">{article.date}</span>
                  <span class="lr-title serif">{article.title}</span>
                  <span class="lr-tag">{article.tag}</span>
                </a>
              ))}
            </div>
          </section>

          <section class="archive-panel" aria-labelledby="archive-events-title">
            <h3 id="archive-events-title" class="serif">Événements passés</h3>
            <div class="list-rows">
              {archivedEvents.map((event) => (
                <div class="list-row">
                  <span class="lr-date">{event.date}</span>
                  <span class="lr-title serif">{event.title}</span>
                  <span class="lr-tag">{event.tag}</span>
                </div>
              ))}
            </div>
          </section>
        </div>
      </div>
    </section>

    <section class="newsletter-section" id="newsletter" data-screen-label="Newsletter">
      <div class="workshops-wrap section-pad">
        <div class="news-grid">
          <div>
            <span class="sec-num">04 - La gazette, dans votre boîte</span>
            <h2 class="title">Recevez les <i class="h">rendez-vous</i> & les conseils.</h2>
            <p class="lede">
              Quelques nouvelles du lieu, des rendez-vous à ne pas manquer, des retours d'expérience, des découvertes et des ressources sélectionnées avec soin.
            </p>
          </div>
          <div>
            <form class="news-form">
              <label for="newsletter-email">
                <span class="sr-only">Adresse e-mail</span>
                <input id="newsletter-email" type="email" placeholder="Votre adresse e-mail" />
              </label>
              <div class="actions news-form-actions">
                <button class="btn btn-accent" type="submit">S'inscrire <span aria-hidden="true">→</span></button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .workshops-page {
    --ateliers: #d6d8d3;
    --ateliers-ink: #545d57;
    --ink-soft: #2a322c;
    background: var(--linen);
  }

  .workshops-wrap {
    width: 100%;
    max-width: var(--site-max);
    margin-inline: auto;
    padding-inline: var(--site-pad-x);
  }

  .section-pad {
    padding-block: var(--site-section-y);
  }

  .rule-top {
    border-top: 1px solid var(--rule);
  }

  .band-paper {
    background: var(--paper);
  }

  .workshops-hero {
    display: grid;
    min-height: var(--site-hero-min-h-fallback);
    min-height: var(--site-hero-min-h);
    align-content: center;
    padding-block: var(--site-hero-pad-block);
    border-bottom: 1px solid var(--rule);
    background: var(--ateliers);
  }

  .page-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(280px, 1fr);
    gap: clamp(32px, 5vw, 72px);
    align-items: end;
  }

  .workshops-hero h1,
  .title {
    margin: 0;
    color: var(--petrol-deep);
    font-family: var(--serif);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    letter-spacing: -0.02em;
  }

  .workshops-hero h1 {
    max-width: none;
    font-size: clamp(40px, 5.8vw, 92px);
    line-height: 1;
  }

  .title {
    font-size: clamp(34px, 5.4vw, 72px);
    line-height: 1.03;
  }

  .h,
  .h-accent {
    font-style: italic;
    font-weight: 300;
  }

  .h-accent,
  .c-petrol {
    color: var(--ateliers-ink);
  }

  .kicker,
  .sec-num {
    color: var(--ateliers-ink);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .kicker {
    margin: 0 0 22px;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
    margin-top: clamp(28px, 3.5vw, 44px);
  }

  .btn {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    gap: 10px;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    padding: 13px 22px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-decoration: none;
    text-transform: uppercase;
    transition: background 260ms ease, color 260ms ease, transform 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)), box-shadow 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1));
  }

  .btn-primary {
    background: var(--petrol);
    color: var(--linen);
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    background: var(--clay);
    transform: translateY(-2px);
    box-shadow: 0 14px 26px rgba(14, 42, 44, 0.16);
  }

  .btn-line {
    position: relative;
    border-bottom: 1px solid transparent;
    background: transparent;
    color: var(--petrol-deep);
    padding-inline: 0;
  }

  .btn-line::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: 4px;
    left: 0;
    height: 1px;
    background: currentColor;
    transform: scaleX(1);
    transform-origin: left;
    transition: transform 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)), background 260ms ease;
  }

  .btn-line:hover,
  .btn-line:focus-visible {
    background: transparent;
    color: var(--clay);
    transform: translateY(-1px);
    box-shadow: none;
  }

  .btn-line:hover::after,
  .btn-line:focus-visible::after {
    transform: scaleX(0.28);
  }

  .ic {
    width: 22px;
    height: 22px;
    flex: none;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.5;
  }

  .page-hero-aside {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .workshops-hero-logo {
    box-sizing: border-box;
    width: clamp(190px, 19vw, 280px);
    height: auto;
    margin-bottom: clamp(4px, 1vw, 10px);
    padding: clamp(14px, 1.6vw, 20px) clamp(16px, 1.9vw, 24px);
    border: 1px solid rgba(31, 38, 34, 0.12);
    border-radius: 6px;
    background: rgba(250, 246, 238, 0.92);
    object-fit: contain;
    box-shadow: 0 18px 42px rgba(31, 38, 34, 0.12);
    filter: contrast(1.04) saturate(1.02) drop-shadow(0 8px 14px rgba(14, 42, 44, 0.12));
  }

  .lede {
    max-width: 480px;
    margin: 0;
    color: var(--ink-soft);
    font-family: var(--serif);
    font-size: clamp(19px, 1.7vw, 23px);
    font-weight: 300;
    line-height: 1.5;
  }

  .sec-head {
    display: flex;
    max-width: 920px;
    flex-direction: column;
    gap: 18px;
  }

  .sec-head.compact {
    gap: 14px;
  }

  .sec-intro {
    max-width: 620px;
    margin: 8px 0 0;
    color: var(--ink-soft);
    font-size: 16.5px;
    line-height: 1.68;
  }

  #agenda.events-planning {
    background: var(--paper);
    padding: var(--site-section-y) 0;
  }

  #agenda .eyebrow,
  #agenda .course-kicker,
  #agenda h2 em,
  #agenda .course-card-feature h3 em,
  #agenda .course-mini-grid p {
    color: var(--ateliers-ink);
  }

  .events {
    display: grid;
    margin-top: clamp(34px, 4vw, 54px);
    border-top: 1px solid var(--rule);
  }

  .event {
    display: grid;
    grid-template-columns: 116px minmax(0, 1fr) auto;
    gap: clamp(18px, 3vw, 42px);
    align-items: center;
    padding: clamp(22px, 3vw, 34px) 0;
    border-bottom: 1px solid var(--rule);
    color: inherit;
    text-decoration: none;
    transition: padding-left 0.2s ease, background 0.2s ease;
  }

  .event:hover,
  .event:focus-visible {
    padding-left: 8px;
  }

  .ev-date {
    display: grid;
    justify-items: start;
    color: var(--ateliers-ink);
  }

  .ev-date .d {
    color: var(--petrol-deep);
    font-size: clamp(42px, 4.8vw, 68px);
    line-height: 0.9;
  }

  .ev-date .m,
  .ev-tag,
  .a-tag,
  .a-foot,
  .lr-date,
  .lr-tag,
  .mono {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .ev-date .m {
    margin-top: 8px;
  }

  .ev-body h3 {
    margin: 0;
    color: var(--petrol-deep);
    font-size: clamp(23px, 2.4vw, 34px);
    line-height: 1.08;
  }

  .ev-body p {
    max-width: 720px;
    margin: 10px 0 0;
    color: var(--granite-500);
    font-size: 14px;
    line-height: 1.6;
  }

  .ev-tag {
    color: var(--ateliers-ink);
    white-space: nowrap;
  }

  .journal-head {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: clamp(28px, 3vw, 40px);
  }

  .journal-head p {
    max-width: 340px;
    margin: 0;
    color: var(--granite-500);
    font-size: 15px;
    line-height: 1.6;
  }

  .articles {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(16px, 2.2vw, 24px);
  }

  .art {
    display: flex;
    overflow: hidden;
    flex-direction: column;
    border: 1px solid var(--rule);
    background: var(--paper);
    color: inherit;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .art:hover,
  .art:focus-visible {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px -28px rgba(14, 42, 44, 0.5);
  }

  .ph {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(62% 54% at 32% 30%, var(--ph-a, #5e8281) 0%, var(--ph-b, #15393b) 78%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(0, 0, 0, 0.18));
  }

  .ph::before {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(43deg, rgba(255, 255, 255, 0.07) 0 1.5px, transparent 1.5px 3px),
      repeating-linear-gradient(137deg, rgba(0, 0, 0, 0.07) 0 1.5px, transparent 1.5px 3px);
    content: "";
    mix-blend-mode: overlay;
    opacity: 0.16;
  }

  .ph::after {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 52%, rgba(14, 42, 44, 0.45) 100%);
    content: "";
  }

  .art .ph {
    width: 100%;
    aspect-ratio: 3 / 2;
  }

  .cap {
    display: none;
    position: absolute;
    z-index: 2;
    right: 14px;
    bottom: 12px;
    left: 14px;
    color: rgba(241, 235, 225, 0.82);
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .t-storm {
    --ph-a: #5e8281;
    --ph-b: #15393b;
  }

  .t-fern {
    --ph-a: #7d9468;
    --ph-b: #2a3d22;
  }

  .t-sand {
    --ph-a: #e0c3a8;
    --ph-b: #a9784f;
  }

  .a-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 10px;
    padding: 22px 22px 24px;
  }

  .a-tag {
    color: var(--ateliers-ink);
  }

  .art h3 {
    margin: 0;
    color: var(--petrol-deep);
    font-size: clamp(20px, 1.8vw, 24px);
    line-height: 1.12;
  }

  .art p {
    margin: 0;
    color: var(--granite-500);
    font-size: 13.5px;
    line-height: 1.55;
  }

  .a-foot {
    margin-top: auto;
    padding-top: 14px;
    border-top: 1px solid var(--rule-soft);
    color: var(--granite-500);
  }

  .archive-link {
    margin-top: 32px;
  }

  .archive-grid {
    display: grid;
    gap: clamp(36px, 4vw, 56px);
  }

  .archive-panel {
    min-width: 0;
  }

  .archive-panel h3 {
    margin: 0;
    color: var(--petrol-deep);
    font-size: clamp(24px, 2.4vw, 34px);
    font-weight: 400;
    line-height: 1.1;
  }

  .list-rows {
    margin-top: clamp(28px, 3vw, 44px);
    border-top: 1px solid var(--rule);
  }

  .list-row {
    display: grid;
    grid-template-columns: 120px minmax(0, 1fr) auto;
    gap: 24px;
    align-items: baseline;
    padding: 22px 0;
    border-bottom: 1px solid var(--rule);
    color: inherit;
    text-decoration: none;
    transition: padding-left 0.2s ease;
  }

  .list-row:hover,
  .list-row:focus-visible {
    padding-left: 8px;
  }

  div.list-row:hover {
    padding-left: 0;
  }

  .lr-date {
    color: var(--granite-500);
  }

  .lr-title {
    color: var(--petrol-deep);
    font-size: clamp(19px, 1.8vw, 24px);
    line-height: 1.15;
  }

  .lr-tag {
    color: var(--ateliers-ink);
    white-space: nowrap;
  }

  .newsletter-section {
    border-top: 1px solid var(--rule);
    background: var(--ateliers);
  }

  .news-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(280px, 1fr);
    gap: clamp(36px, 5vw, 80px);
    align-items: center;
  }

  .news-grid .title {
    margin-top: 16px;
  }

  .news-grid .title i {
    color: var(--ateliers-ink);
  }

  .news-grid .lede {
    margin-top: 22px;
  }

  .news-form {
    display: grid;
    gap: 24px;
    max-width: 520px;
    margin-top: 34px;
  }

  .news-form label {
    border-bottom: 1px solid rgba(14, 42, 44, 0.45);
    transition: border-color 260ms ease;
  }

  .news-form label:focus-within {
    border-color: var(--ateliers-ink);
  }

  .news-form input {
    width: 100%;
    border: 0;
    background: transparent;
    color: var(--petrol-deep);
    font-family: var(--sans);
    font-size: 15px;
    outline: 0;
    padding: 12px 0;
  }

  .news-form input::placeholder {
    color: var(--granite-500);
    transition: color 260ms ease;
  }

  .news-form label:focus-within input::placeholder {
