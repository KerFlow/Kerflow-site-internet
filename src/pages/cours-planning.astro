---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { courseTypes, peopleForSpace, pricingPlans } from "../data/cmsContent.js";

const teachers = peopleForSpace("cours");
---

<BaseLayout
  title="Cours & planning - KerFlow - Clamart"
  description="Yoga, Pilates, mobilite, renforcement doux et respiration en petits groupes a Clamart. Planning, tarifs et informations pour reserver un cours KerFlow."
>
  <SiteHeader />
  <main class="cours-page">
    <section class="cours-hero">
      <div class="cours-wrap">
        <div class="cours-hero-grid">
          <div>
            <p class="cours-kicker">KerFlow Studio - cours collectifs</p>
            <h1>
              Petits groupes,<br />
              <em>pratique attentive.</em><br />
              Bouger sans pression.
            </h1>
            <div class="cours-actions">
              <a href="/contact/" class="btn btn-primary">Réserver un cours <span aria-hidden="true">→</span></a>
              <a href="#planning" class="btn-line">Voir le planning</a>
            </div>
          </div>
          <aside class="cours-hero-aside">
            <img class="cours-hero-logo" src="/assets/logos/kerflow-studio-web.png" alt="KerFlow Studio" loading="eager" decoding="async" />
            <p>
              Une diversité de pratique pour que chacun trouve le mouvement qui lui convient. en <em>petits groupes de 8 à 12 élèves</em>,
              tous les jours, dans Le Salon. Progresser, se renforcer, s'alléger.
            </p>
            <div class="cours-tags">
              <span>yoga</span><span>Pilates</span><span>Renforcement doux</span><span>Mobilité</span><span>Respiration</span>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="cours-section">
      <div class="cours-wrap">
        <div class="cours-head">
          <span class="cours-num">01 - Les pratiques</span>
          <h2>À chacun sa façon<br /><em>de bouger</em></h2>
          <p>Cours adaptés, encadrés de près. On commence où l’on est, on avance à son rythme.</p>
        </div>
        <div class="cours-bordered cols-3">
          {courseTypes.map((course) => (
            <button type="button" class="cours-practice-card" data-course-dialog={`course-${course.slug}`}>
              <span>{course.label}</span>
              <h3>{course.title}</h3>
              <p>{course.description}</p>
            </button>
          ))}
          <div class="highlight">
            <span>→</span>
            <h3>Un doute sur le cours ?</h3>
            <p>On vous oriente avant la premiere seance. Ecrivez-nous, on choisit ensemble.</p>
          </div>
        </div>
        {courseTypes.map((course) => (
          <dialog class="course-dialog" id={`course-${course.slug}`} aria-labelledby={`course-${course.slug}-title`}>
            <button type="button" class="course-dialog-close" data-course-dialog-close aria-label="Fermer">×</button>
            <span>{course.label}</span>
            <h3 id={`course-${course.slug}-title`}>{course.title}</h3>
            <p>{course.longDescription}</p>
          </dialog>
        ))}
      </div>
    </section>

    <section class="cours-section paper">
      <div class="cours-wrap">
        <div class="cours-head">
          <span class="cours-num">02 - Pour qui ?</span>
          <h2>Chacun vient pour<br /><em>une raison différente.</em></h2>
        </div>
        <ul class="cours-check-list">
          <li><span>↘</span><p><strong>Une reprise en douceur</strong> après une pause, une grossesse, un arrêt.</p></li>
          <li><span>↘</span><p><strong>Sportifs & actifs</strong> - gagner en mobilité, récupérer, compléter sa pratique et prévenir les blessures.</p></li>
          <li><span>↘</span><p><strong>Seniors actifs</strong> - des cours adaptés, attentifs, sans esprit de compétition.</p></li>
          <li><span>↘</span><p><strong>Stress & fatigue</strong> - déposer la charge mentale, retrouver du souffle.</p></li>
          <li><span>↘</span><p><strong>À chaque saison de la vie</strong> - grossesse, post-partum, préménopause ou ménopause : des pratiques adaptées aux évolutions du corps.</p></li>
          <li><span>↘</span><p><strong>Douleurs & mobilité</strong> - dénouer, assouplir, soulager sans forcer.</p></li>
        </ul>
      </div>
    </section>

    <section class="cours-section">
      <div class="cours-wrap">
        <div class="cours-split-head">
          <div class="cours-head">
            <span class="cours-num">03 - Pourquoi en petits groupes</span>
            <h2>Ici,<br /><em>chacun compte.</em></h2>
          </div>
          <p>
            Des cours à taille humaine, où l'on profite à la fois de l'énergie du groupe
            et de l'attention portée à chacun. Plus de confort, plus de lien et un accompagnement plus personnalisé.
          </p>
        </div>
        <div class="cours-steps">
          <div><h3>Encadrement attentif</h3><p>Le professeur vous voit, vous accompagne et vous propose des ajustements adaptés à votre pratique.</p></div>
          <div><h3>Cadre chaleureux</h3><p>Moins de monde, plus de confort. Chacun trouve sa place et pratique dans une ambiance sereine.</p></div>
          <div><h3>Dynamique de groupe</h3><p>On retrouve les mêmes visages semaine après semaine, dans une atmosphère conviviale et sans anonymat.</p></div>
        </div>
      </div>
    </section>

    <section id="planning" class="planning planning-cards section-pad">
      <div class="planning-cards-head">
        <div>
            <p class="eyebrow">04 - Le planning de la semaine</p>
            <h2>Les cours<br /><em>du moment.</em></h2>
        </div>
        <div>
          <p>Le planning définitif et la réservation se font sur HelloResa - annulation jusqu'à 24h avant, sans frais.</p>
          <a class="btn-line light" href="/contact/">Réserver via HelloResa →</a>
        </div>
      </div>

      <div class="course-feature-grid">
        <article class="course-card course-card-feature">
          <div class="course-card-copy">
            <p class="course-kicker">↘ A la une cette semaine</p>
            <h3>Yin & souffle<br /><em>mardi 18h30</em></h3>
            <p>75 minutes pour ralentir, ecouter la respiration, deposer la semaine. Format silencieux. Solene M.</p>
            <footer>
              <span>1h15</span>
            </footer>
          </div>
          <div class="photo photo-clay"><span>[ photo - cours du soir, lumiere chaude ]</span></div>
        </article>

        <article class="course-card course-card-photo">
          <div class="photo photo-petrol"><span>[ photo - tapis et bolster ]</span></div>
          <div class="course-card-copy">
            <p class="course-kicker">Mardi - 09h30</p>
            <h4>Hatha doux</h4>
            <p>Solene M. - 1h00</p>
            <footer><a href="/contact/">Réserver →</a></footer>
          </div>
        </article>

        <article class="course-card course-card-photo">
          <div class="photo photo-foam"><span>[ photo - lumiere du matin ]</span></div>
          <div class="course-card-copy">
            <p class="course-kicker">Mercredi - 07h15</p>
            <h4>Vinyasa matin</h4>
            <p>Lea V. - 1h00</p>
            <footer><a href="/contact/">Réserver →</a></footer>
          </div>
        </article>
      </div>

      <div class="course-mini-grid" aria-label="Autres cours de la semaine">
        <article><p>Mer - 12h30</p><h4>Pilates Postural</h4><a href="/contact/">Réserver →</a></article>
        <article><p>Jeu - 18h00</p><h4>Mobilite & renfo</h4><a href="/contact/">Réserver →</a></article>
        <article><p>Jeu - 20h00</p><h4>Yoga restoratif</h4><a href="/contact/">Réserver →</a></article>
        <article><p>Ven - 12h30</p><h4>Mouvement libre</h4><a href="/contact/">Réserver →</a></article>
        <article><p>Ven - 19h00</p><h4>Yin profond</h4><a href="/contact/">Réserver →</a></article>
        <article><p>Sam - 10h00</p><h4>Hatha long</h4><a href="/contact/">Réserver →</a></article>
        <article><p>Sam - 11h45</p><h4>Pilates seniors</h4><a href="/contact/">Réserver →</a></article>
        <article><p>Sam - 16h00</p><h4>Atelier souffle</h4><a href="/contact/">Réserver →</a></article>
      </div>
    </section>

    <section id="tarifs" class="cours-section">
      <div class="cours-wrap">
        <div class="cours-head">
          <span class="cours-num">05 - Tarifs</span>
          <h2>À chacun<br /><em>sa formule.</em></h2>
          <p>Certains poussent la porte pour essayer, d'autres viennent chaque semaine, d'autres choisissent de s'engager dans un cycle.</p>
        </div>
        <div class="cours-pricing">
          {pricingPlans.map((plan) => (
            <div class={plan.featured ? "feature" : undefined}>
              <span>{plan.name}</span>
              {plan.intro && <p>{plan.intro}</p>}
              <ul>
                {plan.features.map((feature) => <li>{feature}</li>)}
              </ul>
              <a href={plan.ctaUrl} class={plan.featured ? "btn btn-primary" : "btn-line"}>{plan.ctaLabel} →</a>
            </div>
          ))}
        </div>
        <p class="cours-note">Si vous avez besoin d'assistance pour réserver, on peut vous aider. <a href="/contact/">Contactez-nous</a> !</p>
      </div>
    </section>

    <section class="cours-section paper">
      <div class="cours-wrap">
        <div class="cours-head">
          <span class="cours-num">06 - Celles et ceux qui enseignent</span>
          <h2>Une équipe<br /><em>attentive.</em></h2>
        </div>
        <div class="cours-team">
          {teachers.map((person) => (
            <article>
              <div class={`cours-portrait ${person.imageClass} ${person.visualMode === "image" && person.image ? "has-upload" : ""}`}>
                {person.visualMode === "image" && person.image ? (
                  <img src={person.image} alt={person.imageLabel} loading="lazy" decoding="async" />
                ) : (
                  <span>{person.imageLabel}</span>
                )}
              </div>
              <div>
                <h3>{person.name}</h3>
                <span>{person.specialty}</span>
                <p>{person.bio}</p>
                <a href={person.secondaryLinkUrl}>{person.secondaryLinkLabel}</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="cours-section">
      <div class="cours-wrap">
        <div class="cours-head">
          <span class="cours-num">07 - Avant de venir</span>
          <h2>Quelques questions<br /><em>que l'on nous pose.</em></h2>
        </div>
        <div class="cours-faq">
          <details><summary>Faut-il être souple ou sportive ?<span></span></summary><p>Non, pas forcément. On vient pour gagner en souplesse et en aisance. Les cours s'adaptent à chaque corps - on commence où l'on en est.</p></details>
          <details><summary>Quel matériel apporter ?<span></span></summary><p>Une tenue confortable, éventuellement votre serviette pour les pratiques au sol et votre gourde. Tapis et matériel sont fournis sur place. Des casiers sont à votre disposition dans les vestiaires.</p></details>
          <details><summary>C'est adapté si je reprends après une longue pause ?<span></span></summary><p>Tout à fait. La plupart de nos cours sont pensés pour les reprises. Dites-le nous, on vous oriente vers le bon créneau.</p></details>
          <details><summary>Et si j'ai des douleurs ?<span></span></summary><p>Signalez-les à l'arrivée : le professeur adapte les postures. Nos cours de Sport Santé sont particulièrement indiqués pour travailler en douceur autour d'une douleur.</p></details>
          <details><summary>Comment réserver et annuler ?<span></span></summary><p>Les réservations se font en ligne via HelloResa. L'annulation est possible jusqu'à 24 heures avant le début du cours, sans frais.</p></details>
        </div>
        <a href="/faq/" class="btn-line">Toutes les questions →</a>
      </div>
    </section>

    <section class="cours-cta">
      <div class="cours-wrap">
        <h2>Votre premier cours<br />est <em>à 10 euros.</em></h2>
        <div>
          <p>Vestiaires, casiers, tisanes en libre accès... Tout est pensé pour que vous vous sentiez à l'aise dès votre arrivée.</p>
          <div class="cours-actions">
            <a href="/contact/" class="btn btn-light">Réserver mon premier cours</a>
            <a href="#planning" class="btn-line on-dark">Voir le planning →</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <script>
    document.querySelectorAll("[data-course-dialog]").forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const dialog = document.getElementById(trigger.dataset.courseDialog);
        if (dialog instanceof HTMLDialogElement) {
          dialog.showModal();
        }
      });
    });

    document.querySelectorAll("[data-course-dialog-close]").forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const dialog = trigger.closest("dialog");
        if (dialog instanceof HTMLDialogElement) {
          dialog.close();
        }
      });
    });

    document.querySelectorAll(".course-dialog").forEach((dialog) => {
      dialog.addEventListener("click", (event) => {
        if (event.target === dialog && dialog instanceof HTMLDialogElement) {
          dialog.close();
        }
      });
    });
  </script>
  <SiteFooter />
</BaseLayout>
