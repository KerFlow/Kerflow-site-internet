---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { courseTypes, peopleForSpace, pricingPlans } from "../data/cmsContent.js";

const teachers = peopleForSpace("cours");
---

<BaseLayout
  title="Cours & planning - KerFlow - Clamart"
  description="Yoga, Pilates, mobilite, renforcement doux et respiration en petits groupes a Clamart. Planning, tarifs et informations pour reserver un cours KerFlow."
>
  <SiteHeader />
  <main class="cours-page">
    <section class="cours-hero">
      <div class="cours-wrap">
        <div class="cours-hero-grid">
          <div>
            <p class="cours-kicker">KerFlow Studio - cours collectifs</p>
            <h1>
              Petits groupes,<br />
              <em>grand soin.</em><br />
              Bouger sans<br />
              pression.
            </h1>
            <div class="cours-actions">
              <a href="/contact/" class="btn btn-primary">Reserver un cours <span aria-hidden="true">→</span></a>
              <a href="#planning" class="btn-line">Voir le planning</a>
            </div>
          </div>
          <aside class="cours-hero-aside">
            <img class="cours-hero-logo" src="/assets/logos/kerflow-studio-web.png" alt="KerFlow Studio" loading="eager" decoding="async" />
            <p>
              Yoga, Pilates, mobilite, respiration - en <em>petits groupes de 8 a 12</em>,
              tous les jours, dans la grande salle. Progresser, se renforcer, se poser.
            </p>
            <div class="cours-tags">
              <span>Yoga</span><span>Pilates</span><span>Mobilite</span><span>Renforcement doux</span><span>Respiration</span>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="cours-section">
      <div class="cours-wrap">
        <div class="cours-head">
          <span class="cours-num">01 - Les pratiques</span>
          <h2>Cinq facons de bouger<br /><em>en douceur.</em></h2>
          <p>Toutes adaptables, toutes encadrees de pres. On commence ou l'on en est, on avance a son rythme.</p>
        </div>
        <div class="cours-bordered cols-3">
          {courseTypes.map((course) => (
            <div>
              <span>{course.label}</span>
              <h3>{course.title}</h3>
              <p>{course.description}</p>
            </div>
          ))}
          <div class="highlight">
            <span>→</span>
            <h3>Un doute sur le cours ?</h3>
            <p>On vous oriente avant la premiere seance. Ecrivez-nous, on choisit ensemble.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="cours-section paper">
      <div class="cours-wrap">
        <div class="cours-head">
          <span class="cours-num">02 - Pour qui ?</span>
          <h2>Pense pour celles et ceux<br />qui veulent <em>reprendre en douceur.</em></h2>
        </div>
        <ul class="cours-check-list">
          <li><span>↘</span><p><strong>Une reprise en douceur</strong> apres une pause, une grossesse, un arret.</p></li>
          <li><span>↘</span><p><strong>Stress & fatigue</strong> - deposer la charge mentale, retrouver du souffle.</p></li>
          <li><span>↘</span><p><strong>Douleurs & mobilite</strong> - denouer, assouplir, soulager sans forcer.</p></li>
          <li><span>↘</span><p><strong>Seniors actifs</strong> - des cours adaptes, attentifs, sans esprit de competition.</p></li>
          <li><span>↘</span><p><strong>Femmes en transition</strong> physique ou emotionnelle, a chaque saison de la vie.</p></li>
          <li><span>↘</span><p><strong>Reprendre confiance</strong> dans son corps, a son propre rythme.</p></li>
        </ul>
      </div>
    </section>

    <section class="cours-section">
      <div class="cours-wrap">
        <div class="cours-split-head">
          <div class="cours-head">
            <span class="cours-num">03 - Pourquoi en petits groupes</span>
            <h2>Huit a douze,<br /><em>jamais plus.</em></h2>
          </div>
          <p>
            Moins de monde, plus de confort. Le professeur vous voit, vous corrige,
            vous adapte le cours. C'est le coeur de la maison.
          </p>
        </div>
        <div class="cours-steps">
          <div><h3>Encadrement attentif</h3><p>Le professeur peut suivre chaque personne, corriger une posture, proposer une variante.</p></div>
          <div><h3>Progression adaptee</h3><p>On ajuste l'intensite au groupe et a chacun - jamais l'inverse.</p></div>
          <div><h3>Un cadre rassurant</h3><p>Pas de regard, pas de performance. On respire, on se sent en securite.</p></div>
        </div>
      </div>
    </section>

    <section id="planning" class="planning planning-cards section-pad">
      <div class="planning-cards-head">
        <div>
          <p class="eyebrow">04 - Le planning de la semaine</p>
          <h2>Une semaine type<br /><em>a la maison.</em></h2>
        </div>
        <div>
          <p>Mardi au samedi. Le planning definitif et la reservation se font sur HelloResa - annulation jusqu'a 4h avant, sans frais.</p>
          <a class="btn-line light" href="/contact/">Reserver via HelloResa →</a>
        </div>
      </div>

      <div class="course-feature-grid">
        <article class="course-card course-card-feature">
          <div class="course-card-copy">
            <p class="course-kicker">↘ A la une cette semaine</p>
            <h3>Yin & souffle<br /><em>mardi 18h30</em></h3>
            <p>75 minutes pour ralentir, ecouter la respiration, deposer la semaine. Format silencieux. Solene M.</p>
            <footer>
              <span>1h15</span>
            </footer>
          </div>
          <div class="photo photo-clay"><span>[ photo - cours du soir, lumiere chaude ]</span></div>
        </article>

        <article class="course-card course-card-photo">
          <div class="photo photo-petrol"><span>[ photo - tapis et bolster ]</span></div>
          <div class="course-card-copy">
            <p class="course-kicker">Mardi - 09h30</p>
            <h4>Hatha doux</h4>
            <p>Solene M. - 1h00</p>
            <footer><a href="/contact/">Reserver →</a></footer>
          </div>
        </article>

        <article class="course-card course-card-photo">
          <div class="photo photo-foam"><span>[ photo - lumiere du matin ]</span></div>
          <div class="course-card-copy">
            <p class="course-kicker">Mercredi - 07h15</p>
            <h4>Vinyasa matin</h4>
            <p>Lea V. - 1h00</p>
            <footer><a href="/contact/">Reserver →</a></footer>
          </div>
        </article>
      </div>

      <div class="course-mini-grid" aria-label="Autres cours de la semaine">
        <article><p>Mer - 12h30</p><h4>Pilates Postural</h4><a href="/contact/">Reserver →</a></article>
        <article><p>Jeu - 18h00</p><h4>Mobilite & renfo</h4><a href="/contact/">Reserver →</a></article>
        <article><p>Jeu - 20h00</p><h4>Yoga restoratif</h4><a href="/contact/">Reserver →</a></article>
        <article><p>Ven - 12h30</p><h4>Mouvement libre</h4><a href="/contact/">Reserver →</a></article>
        <article><p>Ven - 19h00</p><h4>Yin profond</h4><a href="/contact/">Reserver →</a></article>
        <article><p>Sam - 10h00</p><h4>Hatha long</h4><a href="/contact/">Reserver →</a></article>
        <article><p>Sam - 11h45</p><h4>Pilates seniors</h4><a href="/contact/">Reserver →</a></article>
        <article><p>Sam - 16h00</p><h4>Atelier souffle</h4><a href="/contact/">Reserver →</a></article>
      </div>
    </section>

    <section id="tarifs" class="cours-section">
      <div class="cours-wrap">
        <div class="cours-head">
          <span class="cours-num">05 - Tarifs & carnets</span>
          <h2>Clair, simple,<br />sans <em>engagement cache.</em></h2>
          <p>Le 1er cours est à 10 € sur inscription. Ensuite, a vous de voir - a l'unite, en carnet, ou en abonnement.</p>
        </div>
        <div class="cours-pricing">
          {pricingPlans.map((plan) => (
            <div class={plan.featured ? "feature" : undefined}>
              <span>{plan.name}</span>
              <strong>{plan.amount}<sup>€</sup></strong>
              <p>{plan.unit}</p>
              <ul>
                {plan.features.map((feature) => <li>{feature}</li>)}
              </ul>
              <a href={plan.ctaUrl} class={plan.featured ? "btn btn-primary" : "btn-line"}>{plan.ctaLabel} →</a>
            </div>
          ))}
        </div>
        <p class="cours-note">Creneaux a tarif reduit - cours adaptes seniors & post-therapie - le mieux-etre ne doit pas etre un privilege</p>
      </div>
    </section>

    <section class="cours-section paper">
      <div class="cours-wrap">
        <div class="cours-head">
          <span class="cours-num">06 - Celles qui enseignent</span>
          <h2>Des professeures<br /><em>attentives.</em></h2>
        </div>
        <div class="cours-team">
          {teachers.map((person) => (
            <article>
              <div class={`cours-portrait ${person.imageClass}`}><span>{person.imageLabel}</span></div>
              <div>
                <h3>{person.name}</h3>
                <span>{person.specialty}</span>
                <p>{person.bio}</p>
                <a href={person.secondaryLinkUrl}>{person.secondaryLinkLabel}</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="cours-section">
      <div class="cours-wrap">
        <div class="cours-head">
          <span class="cours-num">07 - Avant de venir</span>
          <h2>Quelques questions<br /><em>que l'on nous pose.</em></h2>
        </div>
        <div class="cours-faq">
          <details><summary>Faut-il etre souple ou sportive ?<span></span></summary><p>Non, surtout pas. On vient justement pour gagner en souplesse et en aisance. Les cours s'adaptent a chaque corps - on commence ou l'on en est.</p></details>
          <details><summary>Quel materiel apporter ?<span></span></summary><p>Une tenue confortable et votre serviette pour les pratiques au sol. Tapis, bolsters, briques et materiel sont fournis sur place.</p></details>
          <details><summary>C'est adapte si je reprends apres une longue pause ?<span></span></summary><p>Tout a fait. Les cours de mobilite, Hatha doux et renforcement doux sont penses pour les reprises. Dites-le nous, on vous oriente vers le bon creneau.</p></details>
          <details><summary>Et si j'ai des douleurs ?<span></span></summary><p>Signalez-les a l'arrivee : le professeur adapte les postures. Nos cours de mobilite sont particulierement indiques pour travailler en douceur autour d'une douleur.</p></details>
          <details><summary>Comment reserver et annuler ?<span></span></summary><p>La reservation se fait sur HelloResa. L'annulation est possible jusqu'a 4 heures avant le cours, sans frais - la place est rendue a la liste d'attente.</p></details>
        </div>
        <a href="/faq/" class="btn-line">Toutes les questions →</a>
      </div>
    </section>

    <section class="cours-cta">
      <div class="cours-wrap">
        <h2>Votre 1er cours<br />est <em>à 10 €.</em></h2>
        <div>
          <p>On vous accueille avec un the chaud, on fait le tour de la salle, on commence en douceur. Pas d'engagement, pas de pression.</p>
          <div class="cours-actions">
            <a href="/contact/" class="btn btn-light">Reserver mon 1er cours</a>
            <a href="#planning" class="btn-line on-dark">Voir le planning →</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
