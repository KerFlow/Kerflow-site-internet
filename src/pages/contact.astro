---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import KerflowMapCard from "../components/KerflowMapCard.astro";
import { siteSettings } from "../data/cmsContent.js";

const showPhone = Boolean(siteSettings.phoneVisible && siteSettings.phoneDisplay);
const phoneHref = siteSettings.phoneHref ? `tel:${siteSettings.phoneHref}` : null;
---

<BaseLayout
  title="Contact · KerFlow · Clamart"
  description="Coordonnées, accès, horaires et formulaire de contact KerFlow à Clamart."
>
  <SiteHeader />
  <main class="contact-page">
    <section class="contact-hero section-pad" data-screen-label="Contact · Hero">
      <div class="contact-hero-grid">
        <div>
          <p class="eyebrow">On vous attend</p>
          <h1>
            Venir chez<br />
            <em>KerFlow.</em>
          </h1>
        </div>
        <aside class="contact-hero-aside">
          <p>
            Une maison à deux pas de la gare de Clamart. Poussez la porte, écrivez-nous :
            <em>on prend le temps de répondre</em>.
          </p>
        </aside>
      </div>
    </section>

    <section class="contact-section contact-section-access section-pad" data-screen-label="Coordonnées">
      <div class="contact-grid">
        <div>
          <span class="sec-num">01 · Coordonnées & accès</span>
          <h2 class="contact-title">Au coeur du quartier<br /><em>Gare de Clamart.</em></h2>
          <div class="coord-list">
            <div class="coord-row"><span class="lab">Adresse</span><span class="val">169 avenue Jean Jaures<br />92140 Clamart</span></div>
            <div class="coord-row"><span class="lab">E-mail</span><span class="val"><a href="mailto:kerflow.clamart@gmail.com">kerflow.clamart@gmail.com</a></span></div>
            {showPhone && (
              <div class="coord-row">
                <span class="lab">Téléphone</span>
                <span class="val">{phoneHref ? <a href={phoneHref}>{siteSettings.phoneDisplay}</a> : siteSettings.phoneDisplay}</span>
              </div>
            )}
            <div class="coord-row"><span class="lab">Transport</span><span class="val">Bus 189 - Arrêt Lazare Carnot<br />Transilien N - Clamart (7 min à pied)</span></div>
            <div class="coord-row"><span class="lab">Stationnement</span><span class="val">Zone de stationnement réglementé</span></div>
            <div class="coord-row"><span class="lab">Repères</span><span class="val">Devant l'arrêt de bus Lazare Carnot, en face du Franprix et de l'école Jules Ferry</span></div>
          </div>
        </div>

        <KerflowMapCard />
      </div>
    </section>

    <section class="contact-section contact-section-hours section-pad" data-screen-label="Horaires">
      <div class="sec-head">
        <span class="sec-num">02 · Horaires</span>
        <h2 class="contact-title">Quand<br /><em>venir ?</em></h2>
      </div>
      <div class="contact-steps">
        <div class="contact-step"><h3>Cours collectifs</h3><p>Les cours ont lieu du lundi au samedi selon le planning. Retrouvez les horaires et les disponibilités en ligne. Durant les cours, la porte reste fermée.</p></div>
        <div class="contact-step"><h3>Accompagnements & soins</h3><p>Les accompagnements et les soins sont proposés sur rendez-vous, selon les disponibilités de chaque praticien.</p></div>
        <div class="contact-step"><h3>Découvrir le lieu</h3><p>Vous souhaitez visiter KerFlow, échanger sur un accompagnement ou louer un espace ? Contactez-nous pour convenir d'un rendez-vous.</p></div>
      </div>
    </section>

    <section class="contact-section contact-section-form section-pad" data-screen-label="Formulaire">
      <div class="contact-grid contact-form-grid">
        <div>
          <span class="sec-num">03 · Nous écrire</span>
          <h2 class="contact-title">Une question ?<br /><em>On vous répond.</em></h2>
          <p class="contact-copy">
            Première visite, cours, Accompagnements & soins ou bien demande professionnelle : dites-nous l'essentiel,
            nous reviendrons vers vous dès que possible.
          </p>
        </div>

        <form class="contact-form-card" action="https://formspree.io/f/mykavqkp" method="POST" aria-label="Formulaire de contact" data-formspree-inline data-success-message="Merci, votre message a bien été envoyé. Nous revenons vers vous rapidement.">
          <div class="form-grid">
            <div class="field"><label for="nom">Prénom & nom</label><input id="nom" name="nom" type="text" placeholder="Votre nom" required /></div>
            <div class="field"><label for="mail">E-mail</label><input id="mail" name="email" type="email" placeholder="vous@exemple.fr" required /></div>
            <div class="field full"><label>Votre demande concerne</label>
              <div class="radio-row">
                <label class="radio-chip"><input type="radio" name="sujet" value="Question générale" checked /><span>Question générale</span></label>
                <label class="radio-chip"><input type="radio" name="sujet" value="Première visite" /><span>Première visite</span></label>
                <label class="radio-chip"><input type="radio" name="sujet" value="Accompagnements & Soins" /><span>Accompagnements & Soins</span></label>
                <label class="radio-chip"><input type="radio" name="sujet" value="Demande pro" /><span>Demande pro</span></label>
                <label class="radio-chip"><input type="radio" name="sujet" value="Suggestion" /><span>Suggestion</span></label>
              </div>
            </div>
            <div class="field full"><label for="message">Votre message</label><textarea id="message" name="message" placeholder="Dites-nous comment on peut vous aider..." required></textarea></div>
          </div>
          <div class="form-foot">
            <p class="fine">En envoyant ce formulaire, vous acceptez d'être recontacté·e. Vos données ne sont jamais partagées ni revendues.</p>
            <button type="submit" class="btn contact-submit"><span>Envoyer</span><span aria-hidden="true">→</span></button>
          </div>
        </form>
      </div>
    </section>

    <section id="newsletter" class="contact-cta" data-screen-label="CTA">
      <div class="contact-cta-inner">
        <div>
          <h2>Suivez la vie<br />de la <em>maison.</em></h2>
          <p>
            Les coulisses, les rendez-vous, un conseil de temps en temps. La Gazette passe par Brevo dès que le formulaire final est confirmé.
          </p>
        </div>
        <form class="contact-newsletter-form" onsubmit="return false;" aria-label="Inscription à la gazette KerFlow">
          <label for="contact-newsletter-email">
            <span class="sr-only">Adresse e-mail</span>
            <input id="contact-newsletter-email" type="email" placeholder="Votre adresse e-mail" />
          </label>
          <div class="cta-actions">
            <button class="contact-newsletter-submit" type="submit">Recevoir la gazette <span aria-hidden="true">→</span></button>
          </div>
        </form>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
