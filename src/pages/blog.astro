---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { featuredBlogArticles } from "../data/blogArticles.js";
import { blogSettings } from "../data/cmsContent.js";

const blogFilters = ["Tous", ...new Set(featuredBlogArticles.map((article) => article.tag))];
const articleDuMoment =
  featuredBlogArticles.find((article) => article.slug === blogSettings.featuredArticleSlug) ??
  featuredBlogArticles[0];
---

<BaseLayout
  title="Blog - KerFlow Clamart"
  description="Articles KerFlow autour du sommeil, du stress, de l'alimentation, du mouvement et des accompagnements & soins."
>
  <SiteHeader />
  <main class="blog-page wrapped-sections">
    <section class="blog-hero" data-screen-label="Blog - Hero">
      <div class="blog-wrap">
        <div class="blog-hero-grid">
          <div>
            <p class="kicker">Les articles KerFlow</p>
            <h1 class="serif">
              Des conseils,<br />
              <i class="h-accent">au calme.</i>
            </h1>
          </div>
          <aside>
            <p class="lede">
              Des articles courts et sérieux, écrits par la maison et ses intervenant·es - pour prendre soin de soi entre deux visites.
            </p>
          </aside>
        </div>
      </div>
    </section>

    <section class="section-pad rule-top" data-screen-label="Articles">
      <div class="blog-wrap">
        <div class="journal-head">
          <div class="sec-head compact">
            <span class="sec-num">01 - Tous les articles</span>
            <h2 class="title">Accompagnements & Soins,<br /><i class="h c-accent">mouvement & quotidien.</i></h2>
          </div>
          <p>
            Sommeil, mobilité, alimentation, stress et reprise d'activité: des repères simples pour prolonger KerFlow chez soi.
          </p>
        </div>

        <article class="blog-editorial-feature" aria-label="Article du moment">
          <div class={`photo blog-feature-photo ${articleDuMoment.imageClass} ${articleDuMoment.visualMode === "image" && articleDuMoment.image ? "has-upload" : ""}`}>
            {articleDuMoment.visualMode === "image" && articleDuMoment.image ? (
              <img src={articleDuMoment.image} alt={articleDuMoment.imageLabel} loading="lazy" decoding="async" />
            ) : (
              <span>{articleDuMoment.imageLabel}</span>
            )}
          </div>
          <div class="blog-feature-copy">
            <p class="kicker">Article du moment</p>
            <h2 class="serif">{articleDuMoment.title}</h2>
            <p>{articleDuMoment.excerpt}</p>
            <a class="feature-link" href={`/blog/${articleDuMoment.slug}/`}>Lire l'article</a>
          </div>
        </article>

        <div class="blog-filter-bar" aria-label="Filtrer les articles du blog">
          {blogFilters.map((filter) => (
            <button
              class="blog-filter"
              type="button"
              data-blog-filter={filter === "Tous" ? "all" : filter}
              aria-pressed={filter === "Tous" ? "true" : "false"}
            >
              {filter}
            </button>
          ))}
        </div>

        <div class="articles" data-filter-region="featured" aria-live="polite">
          {featuredBlogArticles.map((article) => (
            <a href={`/blog/${article.slug}/`} class="art" data-blog-item data-blog-tag={article.tag}>
              <div class={`ph ${article.imageClass} ${article.visualMode === "image" && article.image ? "has-upload" : ""}`}>
                {article.visualMode === "image" && article.image ? (
                  <img src={article.image} alt={article.imageLabel} loading="lazy" decoding="async" />
                ) : (
                  <span class="cap">{article.imageLabel}</span>
                )}
              </div>
              <div class="a-body">
                <span class="a-tag">{article.tag}</span>
                <h3 class="serif">{article.title}</h3>
                <p>{article.excerpt}</p>
                <span class="a-foot">Lecture · {article.readingTime}</span>
              </div>
            </a>
          ))}
        </div>
        <p class="filter-empty" data-filter-empty="featured" hidden>
          Aucun article principal dans cette catégorie pour le moment.
        </p>
      </div>
    </section>

    <section class="blog-newsletter" id="newsletter" data-screen-label="Newsletter">
      <div class="blog-wrap section-pad">
        <div class="blog-newsletter-grid">
          <div>
            <span class="sec-num">02 - La gazette, dans votre boîte</span>
            <h2 class="title">Recevez les <i class="h c-accent">repères</i> KerFlow.</h2>
            <p class="lede">
              Une fois par mois - un conseil accompagnements & soins, une idée de mouvement doux et les nouvelles de la maison.
              Jamais plus, jamais de spam.
            </p>
          </div>
          <form class="blog-newsletter-form">
            <label for="blog-newsletter-email">
              <span class="sr-only">Adresse e-mail</span>
              <input id="blog-newsletter-email" type="email" placeholder="Votre adresse e-mail" />
            </label>
            <div class="blog-newsletter-actions">
              <button class="blog-newsletter-submit" type="submit">S'inscrire <span aria-hidden="true">→</span></button>
            </div>
          </form>
        </div>
      </div>
    </section>

  </main>
  <SiteFooter />
</BaseLayout>

<script>
  const filterButtons = document.querySelectorAll("[data-blog-filter]");
  const filterItems = document.querySelectorAll("[data-blog-item]");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const updateFilter = (selectedFilter) => {
    filterButtons.forEach((button) => {
      button.setAttribute("aria-pressed", String(button.dataset.blogFilter === selectedFilter));
    });

    filterItems.forEach((item, index) => {
      const isVisible = selectedFilter === "all" || item.dataset.blogTag === selectedFilter;
      item.hidden = !isVisible;
      item.classList.toggle("is-filtered-in", isVisible);

      if (isVisible && !reduceMotion) {
        item.style.setProperty("--filter-delay", `${Math.min(index * 45, 240)}ms`);
      } else {
        item.style.removeProperty("--filter-delay");
      }
    });

    const visibleCount = document.querySelectorAll('[data-filter-region="featured"] [data-blog-item]:not([hidden])').length;
    const emptyMessage = document.querySelector('[data-filter-empty="featured"]');

    if (emptyMessage) {
      emptyMessage.hidden = visibleCount > 0;
    }
  };

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      updateFilter(button.dataset.blogFilter || "all");
    });
  });
</script>

<style>
  .blog-page {
    --blog-accent: var(--clay);
    --ink-soft: #2a322c;
    background: var(--linen);
  }

  .blog-wrap {
    width: 100%;
    max-width: var(--site-max);
    margin-inline: auto;
    padding-inline: var(--site-pad-x);
  }

  .section-pad {
    padding-block: var(--site-section-y);
  }

  .rule-top {
    border-top: 1px solid var(--rule);
  }

  .band-paper {
    background: var(--paper);
  }

  .blog-hero {
    display: grid;
    min-height: var(--site-hero-min-h-fallback);
    min-height: var(--site-hero-min-h);
    align-content: center;
    padding-block: var(--site-hero-pad-block);
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
  }

  .blog-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(280px, 1fr);
    gap: clamp(32px, 5vw, 72px);
    align-items: end;
  }

  .blog-hero h1,
  .title {
    margin: 0;
    color: var(--petrol-deep);
    font-family: var(--serif);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    letter-spacing: -0.02em;
  }

  .blog-hero h1 {
    font-size: clamp(42px, 6vw, 92px);
    line-height: 1;
  }

  .title {
    font-size: clamp(34px, 5.4vw, 72px);
    line-height: 1.03;
  }

  .h,
  .h-accent {
    font-style: italic;
    font-weight: 300;
  }

  .h-accent,
  .c-accent {
    color: var(--blog-accent);
  }

  .kicker,
  .sec-num {
    color: var(--blog-accent);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .kicker {
    margin: 0 0 22px;
  }

  .lede {
    max-width: 480px;
    margin: 0;
    color: var(--ink-soft);
    font-family: var(--serif);
    font-size: clamp(19px, 1.7vw, 23px);
    font-weight: 300;
    line-height: 1.5;
  }

  .sec-head {
    display: flex;
    max-width: 920px;
    flex-direction: column;
    gap: 18px;
  }

  .sec-head.compact {
    gap: 14px;
  }

  .journal-head {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(280px, 0.22fr);
    gap: clamp(28px, 5vw, 72px);
    align-items: end;
    justify-content: space-between;
    margin-bottom: clamp(40px, 5vw, 72px);
  }

  .journal-head p {
    max-width: 390px;
    margin: 0;
    color: var(--granite-500);
    font-size: clamp(15px, 1.15vw, 17px);
    line-height: 1.68;
  }

  .blog-filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-block: clamp(34px, 4.5vw, 58px) clamp(28px, 3.5vw, 46px);
    padding-block: clamp(16px, 2vw, 24px);
    border-top: 1px solid var(--rule-soft);
  }

  .blog-filter {
    min-height: 42px;
    padding: 0 16px;
    border: 1px solid var(--rule);
    border-radius: 6px;
    background: rgba(250, 246, 238, 0.46);
    color: var(--granite-500);
    cursor: pointer;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .blog-filter:hover,
  .blog-filter:focus-visible {
    border-color: rgba(160, 90, 58, 0.35);
    background: rgba(160, 90, 58, 0.08);
    color: var(--petrol);
    transform: translateY(-2px);
  }

  .blog-filter:focus-visible {
    outline: 2px solid var(--petrol);
    outline-offset: 3px;
  }

  .blog-filter[aria-pressed="true"] {
    border-color: var(--petrol);
    background: var(--petrol);
    color: var(--linen);
    box-shadow: 0 14px 30px -24px rgba(14, 42, 44, 0.55);
  }

  .blog-filter[aria-pressed="true"]:hover,
  .blog-filter[aria-pressed="true"]:focus-visible {
    border-color: var(--clay);
    background: var(--clay);
    color: var(--linen);
  }

  .blog-editorial-feature {
    display: grid;
    overflow: hidden;
    grid-template-columns: minmax(280px, 0.86fr) minmax(0, 1.14fr);
    gap: clamp(28px, 5vw, 72px);
    align-items: stretch;
    margin-bottom: clamp(34px, 5vw, 64px);
    border: 1px solid var(--rule);
    border-radius: 6px;
    background: var(--paper);
    color: inherit;
    transition: border-color 320ms ease, transform 420ms var(--ease-out), box-shadow 420ms var(--ease-out);
  }

  .blog-editorial-feature:hover {
    border-color: rgba(160, 90, 58, 0.24);
    box-shadow: 0 24px 52px rgba(31, 38, 34, 0.08);
    transform: translateY(-4px);
  }

  .blog-feature-photo {
    min-height: 360px;
  }

  .blog-feature-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(28px, 5vw, 64px);
  }

  .blog-feature-copy h2 {
    max-width: 760px;
    margin: 0;
    color: var(--petrol-deep);
    font-family: var(--serif);
    font-size: clamp(34px, 4.8vw, 70px);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .blog-feature-copy p:not(.kicker) {
    max-width: 560px;
    margin: clamp(18px, 2.4vw, 28px) 0 0;
    color: var(--ink-soft);
    font-size: clamp(16px, 1.35vw, 19px);
    line-height: 1.65;
  }

  .feature-link {
    position: relative;
    align-self: flex-start;
    margin-top: clamp(24px, 3vw, 36px);
    color: var(--blog-accent);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .feature-link::after {
    display: block;
    width: 100%;
    height: 1px;
    margin-top: 8px;
    background: currentColor;
    content: "";
    transform-origin: left;
    transition: transform 0.2s ease;
  }

  .feature-link:hover,
  .feature-link:focus-visible {
    color: var(--petrol-deep);
    transform: translateY(-1px);
  }

  .feature-link:hover::after,
  .feature-link:focus-visible::after {
    transform: scaleX(0.35);
  }

  .articles {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(20px, 3vw, 36px);
  }

  .art {
    display: flex;
    overflow: hidden;
    flex-direction: column;
    border: 1px solid var(--rule);
    background: var(--paper);
    color: inherit;
    text-decoration: none;
    transition:
      opacity 0.28s ease,
      transform 0.28s ease,
      box-shadow 0.25s ease;
  }

  .art:hover,
  .art:focus-visible {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px -28px rgba(14, 42, 44, 0.5);
  }

  .art.is-filtered-in {
    animation: filter-rise 0.34s ease both;
    animation-delay: var(--filter-delay, 0ms);
  }

  [data-blog-item][hidden] {
    display: none;
  }

  .ph {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(62% 54% at 32% 30%, var(--ph-a, #5e8281) 0%, var(--ph-b, #15393b) 78%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(0, 0, 0, 0.18));
  }

  .ph::before {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(43deg, rgba(255, 255, 255, 0.07) 0 1.5px, transparent 1.5px 3px),
      repeating-linear-gradient(137deg, rgba(0, 0, 0, 0.07) 0 1.5px, transparent 1.5px 3px);
    content: "";
    mix-blend-mode: overlay;
    opacity: 0.16;
  }

  .ph::after {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 52%, rgba(14, 42, 44, 0.45) 100%);
    content: "";
  }

  .ph.has-upload::before,
  .ph.has-upload::after {
    display: none;
  }

  .ph img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .art .ph {
    width: 100%;
    aspect-ratio: 3 / 2;
  }

  .cap {
    display: none;
    position: absolute;
    z-index: 2;
    right: 14px;
    bottom: 12px;
    left: 14px;
    color: rgba(241, 235, 225, 0.82);
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .t-storm {
    --ph-a: #5e8281;
    --ph-b: #15393b;
  }

  .t-fern {
    --ph-a: #7d9468;
    --ph-b: #2a3d22;
  }

  .t-sand {
    --ph-a: #e0c3a8;
    --ph-b: #a9784f;
  }

  .t-clay {
    --ph-a: #d99a78;
    --ph-b: #8d4f35;
  }

  .t-foam {
    --ph-a: #c9dad7;
    --ph-b: #3f6e6f;
  }

  .t-mist {
    --ph-a: #d6d8d3;
    --ph-b: #545d57;
  }

  .a-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 13px;
    padding: clamp(24px, 2.4vw, 32px);
  }

  .a-tag {
    color: var(--blog-accent);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .art h3 {
    margin: 0;
    color: var(--petrol-deep);
    font-size: clamp(20px, 1.8vw, 24px);
    line-height: 1.12;
  }

  .art p {
    margin: 0;
    color: var(--granite-500);
    font-size: 14px;
    line-height: 1.62;
  }

  .a-foot {
    margin-top: auto;
    padding-top: 18px;
    border-top: 1px solid var(--rule-soft);
    color: var(--granite-500);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .filter-empty {
    margin: 18px 0 0;
    padding: 18px 0;
    border-top: 1px solid var(--rule-soft);
    color: var(--granite-500);
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.45;
  }

  .blog-newsletter {
    border-top: 1px solid var(--rule);
    background: var(--paper);
  }

  .blog-newsletter-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
    gap: clamp(36px, 5vw, 80px);
    align-items: center;
  }

  .blog-newsletter .title {
    margin-top: 16px;
    max-width: 820px;
  }

  .blog-newsletter .lede {
    margin-top: 22px;
  }

  .blog-newsletter-form {
    display: grid;
    gap: 24px;
    max-width: 520px;
    margin: 0;
  }

  .blog-newsletter-form label {
    border-bottom: 1px solid var(--rule);
    transition: border-color 260ms ease;
  }

  .blog-newsletter-form label:focus-within {
    border-color: var(--blog-accent);
  }

  .blog-newsletter-form input {
    width: 100%;
    border: 0;
    background: transparent;
    color: var(--petrol-deep);
    font-family: var(--sans);
    font-size: 15px;
    outline: 0;
    padding: 12px 0;
  }

  .blog-newsletter-form input::placeholder {
    color: var(--granite-500);
    transition: color 260ms ease;
  }

  .blog-newsletter-form label:focus-within input::placeholder {
    color: color-mix(in srgb, var(--blog-accent) 72%, transparent);
  }

  .blog-newsletter-submit {
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    gap: 10px;
    border: 0;
    background: var(--clay);
    color: var(--linen);
    cursor: pointer;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    padding: 0 22px;
    text-transform: uppercase;
    transition: background 260ms ease, transform 300ms var(--ease-out), box-shadow 300ms var(--ease-out);
  }

  .blog-newsletter-submit:hover,
  .blog-newsletter-submit:focus-visible {
    background: var(--petrol-deep);
    box-shadow: 0 14px 26px rgba(14, 42, 44, 0.16);
    transform: translateY(-2px);
  }

  .blog-newsletter-submit:focus-visible {
    outline: 2px solid var(--petrol-deep);
    outline-offset: 3px;
  }

  @keyframes filter-rise {
    from {
      opacity: 0;
      transform: translateY(12px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 900px) {
    .blog-hero-grid,
    .journal-head,
    .blog-editorial-feature,
    .blog-newsletter-grid {
      grid-template-columns: 1fr;
    }

    .blog-feature-photo {
      min-height: clamp(260px, 58vw, 420px);
    }

    .articles {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .journal-head {
      margin-bottom: 34px;
    }

    .blog-filter-bar {
      gap: 8px;
      margin-block: 28px 26px;
    }

    .blog-filter {
      min-height: 40px;
      padding-inline: 13px;
      font-size: 9.5px;
      letter-spacing: 0.14em;
    }

    .articles {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-filter,
    .art,
    .blog-newsletter-submit {
      transition: none;
    }

    .art.is-filtered-in {
      animation: none;
    }
  }
</style>
