---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout
  title="Blog - KerFlow Clamart"
  description="Articles KerFlow autour du sommeil, du stress, de l'alimentation, du mouvement et de la prévention santé."
>
  <SiteHeader />
  <main class="blog-page wrapped-sections">
    <section class="blog-hero" data-screen-label="Blog - Hero">
      <div class="blog-wrap">
        <div class="blog-hero-grid">
          <div>
            <p class="kicker">Le journal KerFlow</p>
            <h1 class="serif">
              Des conseils,<br />
              <i class="h-accent">au calme.</i>
            </h1>
          </div>
          <aside>
            <p class="lede">
              Des articles courts et sérieux, écrits par la maison et ses intervenant·es - pour prendre soin de soi entre deux visites.
            </p>
          </aside>
        </div>
      </div>
    </section>

    <section class="section-pad rule-top" data-screen-label="Articles">
      <div class="blog-wrap">
        <div class="journal-head">
          <div class="sec-head compact">
            <span class="sec-num">01 - Tous les articles</span>
            <h2 class="title">Prévention-santé,<br /><i class="h c-petrol">mouvement & quotidien.</i></h2>
          </div>
          <p>
            Sommeil, mobilité, alimentation, stress et reprise d'activité: des repères simples pour prolonger KerFlow chez soi.
          </p>
        </div>

        <div class="articles">
          <a href="/contact/" class="art">
            <div class="ph t-storm"><span class="cap">[ photo · lumière du soir, chambre ]</span></div>
            <div class="a-body">
              <span class="a-tag">Sommeil</span>
              <h3 class="serif">Cinq gestes du soir pour mieux dormir</h3>
              <p>Ralentir avant le coucher, sans application ni gadget.</p>
              <span class="a-foot">Lecture · 4 min</span>
            </div>
          </a>
          <a href="/contact/" class="art">
            <div class="ph t-fern"><span class="cap">[ photo · marche, mouvement doux ]</span></div>
            <div class="a-body">
              <span class="a-tag">Mouvement</span>
              <h3 class="serif">Reprendre le sport après une longue pause</h3>
              <p>Par où commencer, et comment tenir dans le temps.</p>
              <span class="a-foot">Lecture · 6 min</span>
            </div>
          </a>
          <a href="/contact/" class="art">
            <div class="ph t-sand"><span class="cap">[ photo · table, légumes de saison ]</span></div>
            <div class="a-body">
              <span class="a-tag">Alimentation</span>
              <h3 class="serif">Écouter sa faim, vraiment</h3>
              <p>Le rapport à l'assiette, sans régime ni culpabilité.</p>
              <span class="a-foot">Lecture · 5 min</span>
            </div>
          </a>
          <a href="/contact/" class="art">
            <div class="ph t-clay"><span class="cap">[ photo · respiration, carnet ]</span></div>
            <div class="a-body">
              <span class="a-tag">Stress</span>
              <h3 class="serif">La cohérence cardiaque en 3 minutes</h3>
              <p>Un rituel respiratoire court pour redescendre sans s'isoler.</p>
              <span class="a-foot">Lecture · 3 min</span>
            </div>
          </a>
          <a href="/contact/" class="art">
            <div class="ph t-foam"><span class="cap">[ photo · mouvement, tapis ]</span></div>
            <div class="a-body">
              <span class="a-tag">Prévention</span>
              <h3 class="serif">Bien vieillir : bouger toute sa vie</h3>
              <p>Pourquoi la régularité compte plus que l'intensité.</p>
              <span class="a-foot">Lecture · 5 min</span>
            </div>
          </a>
          <a href="/contact/" class="art">
            <div class="ph t-mist"><span class="cap">[ photo · matin calme, studio ]</span></div>
            <div class="a-body">
              <span class="a-tag">Mouvement</span>
              <h3 class="serif">Reprise d'activité après 50 ans</h3>
              <p>Retrouver confiance dans le mouvement, étape par étape.</p>
              <span class="a-foot">Lecture · 6 min</span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section class="section-pad rule-top band-paper" data-screen-label="Archives articles">
      <div class="blog-wrap">
        <div class="sec-head">
          <span class="sec-num">02 - Archives</span>
          <h2 class="title">Les derniers<br /><i class="h c-petrol">repères.</i></h2>
        </div>
        <div class="list-rows">
          <a href="/contact/" class="list-row"><span class="lr-date">Mai 2026</span><span class="lr-title serif">Stress : la cohérence cardiaque en 3 minutes</span><span class="lr-tag">Stress · Article</span></a>
          <a href="/contact/" class="list-row"><span class="lr-date">Avr. 2026</span><span class="lr-title serif">Bien vieillir : bouger toute sa vie</span><span class="lr-tag">Prévention · Article</span></a>
          <a href="/contact/" class="list-row"><span class="lr-date">Mars 2026</span><span class="lr-title serif">Reprise d'activité après 50 ans</span><span class="lr-tag">Mouvement · Article</span></a>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .blog-page {
    --blog-accent: var(--petrol);
    --ink-soft: #2a322c;
    background: var(--linen);
  }

  .blog-wrap {
    width: 100%;
    max-width: var(--site-max);
    margin-inline: auto;
    padding-inline: var(--site-pad-x);
  }

  .section-pad {
    padding-block: var(--site-section-y);
  }

  .rule-top {
    border-top: 1px solid var(--rule);
  }

  .band-paper {
    background: var(--paper);
  }

  .blog-hero {
    display: grid;
    min-height: calc(72vh - 86px);
    align-content: center;
    padding-block: clamp(56px, 8vw, 104px);
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
  }

  .blog-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(280px, 1fr);
    gap: clamp(32px, 5vw, 72px);
    align-items: end;
  }

  .blog-hero h1,
  .title {
    margin: 0;
    color: var(--petrol-deep);
    font-family: var(--serif);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    letter-spacing: -0.02em;
  }

  .blog-hero h1 {
    font-size: clamp(42px, 6vw, 92px);
    line-height: 1;
  }

  .title {
    font-size: clamp(34px, 5.4vw, 72px);
    line-height: 1.03;
  }

  .h,
  .h-accent {
    font-style: italic;
    font-weight: 300;
  }

  .h-accent,
  .c-petrol {
    color: var(--blog-accent);
  }

  .kicker,
  .sec-num {
    color: var(--blog-accent);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .kicker {
    margin: 0 0 22px;
  }

  .lede {
    max-width: 480px;
    margin: 0;
    color: var(--ink-soft);
    font-family: var(--serif);
    font-size: clamp(19px, 1.7vw, 23px);
    font-weight: 300;
    line-height: 1.5;
  }

  .sec-head {
    display: flex;
    max-width: 920px;
    flex-direction: column;
    gap: 18px;
  }

  .sec-head.compact {
    gap: 14px;
  }

  .journal-head {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: clamp(28px, 3vw, 40px);
  }

  .journal-head p {
    max-width: 340px;
    margin: 0;
    color: var(--granite-500);
    font-size: 15px;
    line-height: 1.6;
  }

  .articles {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(16px, 2.2vw, 24px);
  }

  .art {
    display: flex;
    overflow: hidden;
    flex-direction: column;
    border: 1px solid var(--rule);
    background: var(--paper);
    color: inherit;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .art:hover,
  .art:focus-visible {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px -28px rgba(14, 42, 44, 0.5);
  }

  .ph {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(62% 54% at 32% 30%, var(--ph-a, #5e8281) 0%, var(--ph-b, #15393b) 78%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(0, 0, 0, 0.18));
  }

  .ph::before {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(43deg, rgba(255, 255, 255, 0.07) 0 1.5px, transparent 1.5px 3px),
      repeating-linear-gradient(137deg, rgba(0, 0, 0, 0.07) 0 1.5px, transparent 1.5px 3px);
    content: "";
    mix-blend-mode: overlay;
    opacity: 0.16;
  }

  .ph::after {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 52%, rgba(14, 42, 44, 0.45) 100%);
    content: "";
  }

  .art .ph {
    width: 100%;
    aspect-ratio: 3 / 2;
  }

  .cap {
    position: absolute;
    z-index: 2;
    right: 14px;
    bottom: 12px;
    left: 14px;
    color: rgba(241, 235, 225, 0.82);
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .t-storm {
    --ph-a: #5e8281;
    --ph-b: #15393b;
  }

  .t-fern {
    --ph-a: #7d9468;
    --ph-b: #2a3d22;
  }

  .t-sand {
    --ph-a: #e0c3a8;
    --ph-b: #a9784f;
  }

  .t-clay {
    --ph-a: #d99a78;
    --ph-b: #8d4f35;
  }

  .t-foam {
    --ph-a: #c9dad7;
    --ph-b: #3f6e6f;
  }

  .t-mist {
    --ph-a: #d6d8d3;
    --ph-b: #545d57;
  }

  .a-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 10px;
    padding: 22px 22px 24px;
  }

  .a-tag {
    color: var(--blog-accent);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .art h3 {
    margin: 0;
    color: var(--petrol-deep);
    font-size: clamp(20px, 1.8vw, 24px);
    line-height: 1.12;
  }

  .art p {
    margin: 0;
    color: var(--granite-500);
    font-size: 13.5px;
    line-height: 1.55;
  }

  .a-foot {
    margin-top: auto;
    padding-top: 14px;
    border-top: 1px solid var(--rule-soft);
    color: var(--granite-500);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .list-rows {
    margin-top: clamp(28px, 3vw, 44px);
    border-top: 1px solid var(--rule);
  }

  .list-row {
    display: grid;
    grid-template-columns: 120px minmax(0, 1fr) auto;
    gap: 24px;
    align-items: baseline;
    padding: 22px 0;
    border-bottom: 1px solid var(--rule);
    color: inherit;
    text-decoration: none;
    transition: padding-left 0.2s ease;
  }

  .list-row:hover,
  .list-row:focus-visible {
    padding-left: 8px;
  }

  .lr-date,
  .lr-tag {
    color: var(--granite-500);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .lr-title {
    color: var(--petrol-deep);
    font-size: clamp(19px, 1.8vw, 24px);
    line-height: 1.15;
  }

  .lr-tag {
    color: var(--blog-accent);
    white-space: nowrap;
  }

  @media (max-width: 900px) {
    .blog-hero-grid {
      grid-template-columns: 1fr;
    }

    .articles {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .articles,
    .list-row {
      grid-template-columns: 1fr;
    }

    .lr-tag {
      display: none;
    }
  }
</style>
