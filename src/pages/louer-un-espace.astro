---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout
  title="Louer un espace - KerFlow Clamart"
  description="Location d'espaces KerFlow pour professeur·es, thérapeutes, praticien·nes, ateliers, conférences et professionnel·les de prévention santé."
>
  <SiteHeader />
  <main class="rent-page page wrapped-sections">
    <section class="page-hero tinted" data-screen-label="Louer · Hero">
      <div class="wrap">
        <div class="page-hero-grid">
          <div>
            <p class="kicker">Pour les professionnel·les</p>
            <h1 class="serif">
              Louer un espace<br />
              au sein de la<br />
              <i class="h-accent">maison <span class="brand-word-accent">KerFlow</span>.</i>
            </h1>
            <div class="hero-cta">
              <a href="#demande" class="btn btn-primary">
                Faire une demande
                <svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 12h16M14 6l6 6-6 6"></path></svg>
              </a>
              <a href="#espaces" class="btn-line">Voir les espaces</a>
            </div>
          </div>
          <aside class="page-hero-aside">
            <p class="lede">
              Trois espaces rénovés - une grande salle, un cabinet, un box de soin - à louer à
              l'heure, à la demi-journée ou à la journée, dans un <i class="h">écosystème bien-être déjà vivant</i>.
            </p>
            <div class="hero-tags">
              <span>Salle 40 m²</span>
              <span>Cabinet 11 m²</span>
              <span>Box 7 m²</span>
              <span>Tisanerie</span>
              <span>Clientèle locale</span>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="section-pad band-linen" data-screen-label="Pour qui">
      <div class="wrap">
        <div class="sec-head">
          <span class="sec-num">01 - Pour qui ?</span>
          <h2 class="title">Des professionnel·les<br /><i class="h c-petrol">aligné·es</i> avec le lieu.</h2>
          <p class="sec-intro">
            Une clientèle déjà sensible aux démarches de bien-être et de prévention santé, un cadre qualitatif, un univers cohérent. Si c'est le vôtre, on devrait s'entendre.
          </p>
        </div>
        <div class="grid-bordered cols-3">
          <div class="gb-cell"><span class="gb-num">↘</span><h3 class="serif">Professeur·es</h3><p>Yoga, Pilates, mobilité, pratiques douces - cours réguliers ou cycles.</p></div>
          <div class="gb-cell"><span class="gb-num">↘</span><h3 class="serif">Thérapeutes & masseur·ses</h3><p>Massage, réflexologie, acupuncture, soins énergétiques, soins du corps.</p></div>
          <div class="gb-cell"><span class="gb-num">↘</span><h3 class="serif">Prévention santé</h3><p>Nutrition, sommeil, accompagnement, coaching - consultations individuelles.</p></div>
          <div class="gb-cell"><span class="gb-num">↘</span><h3 class="serif">Ateliers & conférences</h3><p>Cercles, formations, workshops, stages week-end ouverts au public.</p></div>
          <div class="gb-cell"><span class="gb-num">↘</span><h3 class="serif">Intervenant·es réguliers</h3><p>On privilégie les partenariats durables, inscrits dans la vie du lieu.</p></div>
          <div class="gb-cell highlight"><span class="gb-num">→</span><h3 class="serif">Un projet particulier ?</h3><p>Parlez-nous-en. On étudie chaque demande au cas par cas.</p></div>
        </div>
      </div>
    </section>

    <section class="section-pad rule-top band-paper" id="espaces" data-screen-label="Espaces à louer">
      <div class="wrap">
        <div class="sec-head">
          <span class="sec-num">02 - Les espaces disponibles</span>
          <h2 class="title">Trois espaces,<br />trois <i class="h c-petrol">usages.</i></h2>
          <p class="sec-intro">
            Tous entièrement rénovés - double vitrage, peintures et sols neufs. Tisanerie, vestiaires et toilettes accessibles PMR partagés.
          </p>
        </div>

        <div class="rent space-studio" data-screen-label="Louer · La Salle">
          <div class="rent-media framed">
            <div class="ph t-petrol"><span class="cap">[ photo · La Salle de pratique, 40 m², miroir toute hauteur, lumière naturelle ]</span></div>
          </div>
          <div class="rent-body">
            <span class="r-tag">01 · La Salle de pratique</span>
            <h3 class="serif">Salle polyvalente · 40 m²</h3>
            <p class="r-desc">
              Lumineuse et chaleureuse, prête à accueillir jusqu'à 10-12 participants pour une pratique corporelle. Idéale pour les cours collectifs, ateliers, formations, cercles, conférences - mais aussi stages week-end et workshops.
            </p>
            <ul class="r-equip">
              <li>Tapis, bolsters, briques & sangles</li>
              <li>Couvertures & élastiques Pilates</li>
              <li>Balles & gros ballons</li>
              <li>6 tables & 20 chaises pliantes</li>
              <li>Miroir toute hauteur</li>
              <li>Enceinte Bluetooth</li>
            </ul>
            <div class="r-tarifs">
              <div class="r-tarif"><span class="rt-amt">15<sup>€</sup></span><span class="rt-unit">de l'heure</span></div>
              <div class="r-tarif"><span class="rt-amt">50<sup>€</sup></span><span class="rt-unit">demi-journée · 5h</span></div>
              <div class="r-tarif"><span class="rt-amt">100<sup>€</sup></span><span class="rt-unit">journée · 10h</span></div>
            </div>
            <p class="r-cond">Capacité 12 · à l'heure, demi-journée ou journée · tarifs indicatifs</p>
            <div class="space-action">
              <a href="#demande" class="btn space-btn">
                Demander cet espace
                <svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 12h16M14 6l6 6-6 6"></path></svg>
              </a>
            </div>
          </div>
        </div>

        <div class="rent flip space-consult" data-screen-label="Louer · La Bulle">
          <div class="rent-media framed">
            <div class="ph t-foam"><span class="cap">[ photo · La Bulle, 11 m², grande fenêtre sur cour arborée, fauteuil ]</span></div>
          </div>
          <div class="rent-body">
            <span class="r-tag">02 · La Bulle - bureau de consultation</span>
            <h3 class="serif">Cabinet lumineux · 11 m²</h3>
            <p class="r-desc">
              Au rez-de-chaussée, une grande fenêtre ouvrant sur une cour calme et arborée. Un climat de confiance et de sérénité dès l'entrée - idéal pour l'accompagnement thérapeutique, la prévention santé ou le coaching.
            </p>
            <ul class="r-equip">
              <li>Rez-de-chaussée · accès PMR</li>
              <li>Grande fenêtre sur cour</li>
              <li>Double vitrage · sol neuf</li>
              <li>Tisanerie partagée</li>
              <li>Toilettes accessibles PMR</li>
              <li>Ambiance naturelle & chaleureuse</li>
            </ul>
            <div class="r-tarifs">
              <div class="r-tarif"><span class="rt-amt">12<sup>€</sup></span><span class="rt-unit">de l'heure</span></div>
              <div class="r-tarif"><span class="rt-amt">45<sup>€</sup></span><span class="rt-unit">demi-journée · 5h</span></div>
              <div class="r-tarif"><span class="rt-amt">90<sup>€</sup></span><span class="rt-unit">journée · 10h</span></div>
            </div>
            <p class="r-cond">Consultation & accompagnement · à l'heure, demi-journée ou journée</p>
            <div class="space-action">
              <a href="#demande" class="btn space-btn">
                Demander cet espace
                <svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 12h16M14 6l6 6-6 6"></path></svg>
              </a>
            </div>
          </div>
        </div>

        <div class="rent space-rituel" data-screen-label="Louer · Le Cocon">
          <div class="rent-media framed">
            <div class="ph t-clay"><span class="cap">[ photo · Le Cocon, 7 m², box de soin au sous-sol, table de massage ]</span></div>
          </div>
          <div class="rent-body">
            <span class="r-tag">03 · Le Cocon - box de soin</span>
            <h3 class="serif">Box intimiste · 7 m²</h3>
            <p class="r-desc">
              Au sous-sol, à proximité des vestiaires. Sans fenêtre, il offre une intimité totale et une atmosphère enveloppante, propice au lâcher-prise - pour le massage, l'acupuncture ou les soins énergétiques.
            </p>
            <ul class="r-equip">
              <li>Table de massage portative</li>
              <li>Petit lavabo · radiateur</li>
              <li>Enceinte Bluetooth</li>
              <li>VMC · renouvellement d'air</li>
              <li>Intimité & confidentialité</li>
              <li>Non PMR · transfert possible à l'étage</li>
            </ul>
            <div class="r-tarifs">
              <div class="r-tarif"><span class="rt-amt">10<sup>€</sup></span><span class="rt-unit">de l'heure</span></div>
              <div class="r-tarif"><span class="rt-amt">40<sup>€</sup></span><span class="rt-unit">demi-journée · 5h</span></div>
              <div class="r-tarif"><span class="rt-amt">70<sup>€</sup></span><span class="rt-unit">journée · 10h</span></div>
            </div>
            <p class="r-cond">Soin individuel · à l'heure, demi-journée ou journée · tarifs indicatifs</p>
            <div class="space-action">
              <a href="#demande" class="btn space-btn">
                Demander cet espace
                <svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 12h16M14 6l6 6-6 6"></path></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-pad rule-top band-base-soft" data-screen-label="Pourquoi rejoindre">
      <div class="wrap">
        <div class="sec-head">
          <span class="sec-num">03 - Pourquoi rejoindre KerFlow</span>
          <h2 class="title">Un lieu où votre<br />activité <i class="h c-petrol">se prolonge.</i></h2>
        </div>
        <ul class="check-list">
          <li><span class="mk">↘</span><span class="tx"><b>Un lieu qualitatif</b> - entièrement rénové, matériaux soignés, ambiance apaisée.</span></li>
          <li><span class="mk">↘</span><span class="tx"><b>Une clientèle locale</b> déjà engagée dans une démarche de bien-être.</span></li>
          <li><span class="mk">↘</span><span class="tx"><b>Un univers cohérent</b> - prévention-santé clair, positionnement assumé.</span></li>
          <li><span class="mk">↘</span><span class="tx"><b>Un cadre chaleureux</b> - tisanerie conviviale, vestiaires, accueil soigné.</span></li>
          <li><span class="mk">↘</span><span class="tx"><b>Une optimisation du planning</b> - créneaux fixes, cycles réguliers, stages rentables.</span></li>
          <li><span class="mk">↘</span><span class="tx"><b>Une ambiance professionnelle</b> mais humaine, à taille d'une maison.</span></li>
        </ul>
      </div>
    </section>

    <section class="section-pad rule-top band-request" id="demande" data-screen-label="Demande de location">
      <div class="wrap">
        <div class="contact-grid">
          <div>
            <span class="sec-num">04 - Demande de location</span>
            <h2 class="title request-title">Parlez-nous de<br /><i class="h">votre projet.</i></h2>
            <p class="request-copy">
              Dites-nous qui vous êtes, l'espace qui vous intéresse et le rythme souhaité. On revient vers vous sous 48 h pour fixer une visite et vérifier les disponibilités.
            </p>
            <div class="coord-list">
              <div class="coord-row"><span class="lab">Contact direct</span><span class="val"><a href="mailto:bonjour@kerflow.fr">bonjour@kerflow.fr</a></span></div>
              <div class="coord-row"><span class="lab">Téléphone</span><span class="val"><a href="tel:+33146381234">01 46 38 12 34</a></span></div>
              <div class="coord-row"><span class="lab">Visite</span><span class="val">Sur rendez-vous, du mardi au samedi</span></div>
            </div>
          </div>
          <form class="form-card" onsubmit="return false;" aria-label="Demande de location">
            <div class="form-grid">
              <div class="field"><label for="ln">Prénom & nom</label><input id="ln" type="text" placeholder="Votre nom" /></div>
              <div class="field"><label for="ac">Activité</label><input id="ac" type="text" placeholder="Ex. réflexologue, prof de yoga..." /></div>
              <div class="field"><label for="em">E-mail</label><input id="em" type="email" placeholder="vous@exemple.fr" /></div>
              <div class="field"><label for="phone">Téléphone</label><input id="phone" type="tel" placeholder="06 00 00 00 00" /></div>
              <div class="field full">
                <label>Espace souhaité</label>
                <div class="radio-row">
                  <label class="radio-chip"><input type="radio" name="space" checked /><span>La Salle · 40 m²</span></label>
                  <label class="radio-chip"><input type="radio" name="space" /><span>La Bulle · 11 m²</span></label>
                  <label class="radio-chip"><input type="radio" name="space" /><span>Le Cocon · 7 m²</span></label>
                </div>
              </div>
              <div class="field full">
                <label>Rythme</label>
                <div class="radio-row">
                  <label class="radio-chip"><input type="radio" name="freq" checked /><span>Heure</span></label>
                  <label class="radio-chip"><input type="radio" name="freq" /><span>Demi-journée</span></label>
                  <label class="radio-chip"><input type="radio" name="freq" /><span>Journée</span></label>
                  <label class="radio-chip"><input type="radio" name="freq" /><span>Cycle régulier</span></label>
                </div>
              </div>
              <div class="field full"><label for="msg">Votre projet</label><textarea id="msg" placeholder="Décrivez votre activité, vos créneaux idéaux, vos questions..."></textarea></div>
            </div>
            <div class="form-foot">
              <p class="fine">En envoyant ce formulaire, vous acceptez d'être recontacté·e au sujet de votre demande. Aucune donnée n'est partagée.</p>
              <button type="submit" class="btn btn-primary">
                Envoyer ma demande
                <svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 12h16M14 6l6 6-6 6"></path></svg>
              </button>
            </div>
          </form>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .rent-page {
    --base-soft: var(--stone);
    --base-quiet: var(--bone);
    --accent: var(--clay);
    --accent-ink: var(--clay);
    --accent-soft: var(--base-soft);
    --frame: var(--base-soft);
    background: var(--linen);
    color: var(--petrol-deep);
  }

  .wrap {
    max-width: var(--site-max);
    margin: 0 auto;
    padding-inline: var(--site-pad-x);
  }

  .serif {
    font-family: var(--serif);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
  }

  .h,
  .h-accent {
    font-style: italic;
  }

  .c-petrol,
  .h-accent {
    color: var(--clay);
  }

  .brand-word-accent {
    color: var(--petrol);
  }

  .section-pad {
    padding-block: var(--site-section-y);
  }

  .rule-top {
    border-top: 1px solid var(--rule);
  }

  .band-paper {
    background: var(--paper);
  }

  .band-linen {
    background: var(--linen);
  }

  .band-base-soft {
    background: var(--bone);
  }

  .band-request {
    background: var(--linen);
  }

  .page-hero {
    display: flex;
    grid-template-columns: none;
    gap: 0;
    min-height: calc(100vh - 86px);
    min-height: calc(100svh - 86px);
    align-items: center;
    padding-block: clamp(40px, 6vw, 72px) clamp(40px, 5vw, 64px);
  }

  .page-hero > .wrap {
    width: 100%;
  }

  .page-hero.tinted {
    border-bottom: 1px solid var(--rule);
    background: var(--bone);
  }

  .page-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(280px, 1fr);
    gap: clamp(32px, 5vw, 72px);
    align-items: end;
  }

  .page-hero h1,
  h2.title {
    margin: 0;
    color: var(--petrol-deep);
    font-family: var(--serif);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    letter-spacing: -0.02em;
  }

  .page-hero h1 {
    max-width: none;
    font-size: clamp(40px, 5.8vw, 92px);
    line-height: 1;
  }

  h2.title {
    font-size: clamp(34px, 5.4vw, 72px);
    line-height: 1.03;
  }

  .kicker,
  .sec-num,
  .gb-num,
  .r-tag,
  .rt-unit,
  .r-cond {
    font-family: var(--mono);
    text-transform: uppercase;
  }

  .kicker,
  .sec-num {
    color: var(--accent-ink);
    font-size: 11px;
    letter-spacing: 0.24em;
  }

  .kicker {
    margin: 0 0 22px;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
    margin-top: clamp(28px, 3.5vw, 44px);
  }

  .btn {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    gap: 10px;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    padding: 13px 22px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-decoration: none;
    text-transform: uppercase;
    transition: background 260ms ease, color 260ms ease, transform 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)), box-shadow 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1));
  }

  .btn-primary {
    background: var(--petrol);
    color: var(--linen);
  }

  .btn-primary:hover,
  .btn-primary:focus-visible {
    background: var(--clay);
    transform: translateY(-2px);
    box-shadow: 0 14px 26px rgba(14, 42, 44, 0.16);
  }

  .btn-line {
    position: relative;
    border-bottom: 1px solid transparent;
    background: transparent;
    color: var(--petrol-deep);
    padding-inline: 0;
  }

  .btn-line::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: 4px;
    left: 0;
    height: 1px;
    background: currentColor;
    transform: scaleX(1);
    transform-origin: left;
    transition: transform 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)), background 260ms ease;
  }

  .btn-line:hover::after,
  .btn-line:focus-visible::after {
    transform: scaleX(0.28);
  }

  .ic {
    width: 22px;
    height: 22px;
    flex: none;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.5;
  }

  .page-hero-aside {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .lede {
    max-width: 420px;
    margin: 0;
    color: var(--ink-soft, var(--granite));
    font-family: var(--serif);
    font-size: clamp(19px, 1.7vw, 23px);
    font-weight: 300;
    line-height: 1.5;
  }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .hero-tags span {
    border: 1px solid var(--rule);
    padding: 6px 11px;
    color: var(--granite-500);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .sec-head {
    display: flex;
    max-width: 920px;
    flex-direction: column;
    gap: 18px;
  }

  .sec-intro {
    max-width: 620px;
    margin: 8px 0 0;
    color: var(--ink-soft, var(--granite));
    font-size: 16.5px;
    line-height: 1.68;
  }

  .grid-bordered {
    display: grid;
    margin-top: clamp(32px, 4vw, 52px);
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
  }

  .grid-bordered.cols-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .gb-cell {
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-height: 190px;
    padding: 30px clamp(20px, 2vw, 32px);
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .gb-cell.highlight {
    border-color: var(--accent-soft);
    background: var(--accent-soft);
  }

  .gb-num {
    color: var(--accent-ink);
    font-size: 11px;
    letter-spacing: 0.2em;
  }

  .gb-cell h3 {
    margin: 0;
    color: var(--petrol-deep);
    font-size: clamp(22px, 2vw, 28px);
    line-height: 1.05;
  }

  .gb-cell p {
    margin: 0;
    color: var(--granite-500);
    font-size: 14px;
    line-height: 1.6;
  }

  .ph {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: var(--ph-a, #3b6c6e);
    background-image:
      radial-gradient(62% 54% at 32% 30%, var(--ph-a, #3b6c6e) 0%, var(--ph-b, #0e2a2c) 78%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(0, 0, 0, 0.18));
  }

  .ph::before,
  .ph::after {
    position: absolute;
    inset: 0;
    content: "";
    pointer-events: none;
  }

  .ph::before {
    background:
      repeating-linear-gradient(43deg, rgba(255, 255, 255, 0.07) 0 1.5px, transparent 1.5px 3px),
      repeating-linear-gradient(137deg, rgba(0, 0, 0, 0.07) 0 1.5px, transparent 1.5px 3px);
    mix-blend-mode: overlay;
    opacity: 0.16;
  }

  .ph::after {
    background: linear-gradient(180deg, transparent 52%, rgba(14, 42, 44, 0.45));
  }

  .ph .cap {
    position: absolute;
    right: 14px;
    bottom: 12px;
    left: 14px;
    z-index: 2;
    color: rgba(241, 235, 225, 0.82);
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .t-petrol {
    --ph-a: #3b6c6e;
    --ph-b: #0e2a2c;
  }

  .t-foam {
    --ph-a: #9bbab8;
    --ph-b: #3f6e6f;
  }

  .t-clay {
    --ph-a: #c47a55;
    --ph-b: #6b3d29;
  }

  .framed {
    padding: 12px;
    background: var(--frame, var(--stone));
  }

  .rent {
    display: grid;
