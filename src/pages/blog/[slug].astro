---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { blogArticles } from "../../data/blogArticles.js";

export function getStaticPaths() {
  return blogArticles.map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props;
const relatedArticles = blogArticles
  .filter((item) => item.slug !== article.slug)
  .slice(0, 3);
const slugifyHeading = (value) =>
  value
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
const articleSections = article.sections.map((section) => ({
  ...section,
  id: slugifyHeading(section.heading)
}));
---

<BaseLayout
  title={`${article.title} - Blog KerFlow`}
  description={article.excerpt}
>
  <SiteHeader />
  <main class="article-page wrapped-sections">
    <article>
      <header class="article-hero" data-screen-label="Article - Hero">
        <div class="article-wrap">
          <a href="/blog/" class="back-link">
            <span aria-hidden="true">←</span>
            Retour au blog
          </a>
          <div class="article-hero-grid">
            <div class="article-title-block">
              <p class="kicker">{article.tag} · {article.date} · Lecture {article.readingTime}</p>
              <h1 class="serif">{article.title}</h1>
              <p class="lede">{article.intro}</p>
            </div>
            <div class={`ph article-photo ${article.imageClass} ${article.visualMode === "image" && article.image ? "has-upload" : ""}`}>
              {article.visualMode === "image" && article.image ? (
                <img src={article.image} alt={article.imageLabel} loading="eager" decoding="async" />
              ) : (
                <span class="cap">{article.imageLabel}</span>
              )}
            </div>
          </div>
        </div>
      </header>

      <section class="article-content-section" data-screen-label="Article - Contenu">
        <div class="article-content">
          <nav class="faq-toc article-toc" aria-label="Sommaire de l'article">
            {articleSections.map((section) => (
              <a href={`#${section.id}`}>{section.heading}</a>
            ))}
          </nav>
          <div class="article-body">
            {articleSections.map((section) => (
              <section id={section.id}>
                <h2 class="serif">{section.heading}</h2>
                {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
              </section>
            ))}
          </div>
        </div>
      </section>
    </article>

    <section class="related-section rule-top band-paper" data-screen-label="Articles liés">
      <div class="article-wrap">
        <div class="related-head">
          <span class="sec-num">À lire aussi</span>
          <h2 class="serif">D'autres repères<br /><i>KerFlow.</i></h2>
        </div>
        <div class="related-grid">
          {relatedArticles.map((item) => (
            <a href={`/blog/${item.slug}/`} class="art">
              <div class={`ph ${item.imageClass} ${item.visualMode === "image" && item.image ? "has-upload" : ""}`}>
                {item.visualMode === "image" && item.image ? (
                  <img src={item.image} alt={item.imageLabel} loading="lazy" decoding="async" />
                ) : (
                  <span class="cap">{item.imageLabel}</span>
                )}
              </div>
              <div class="a-body">
                <span class="a-tag">{item.tag}</span>
                <h3 class="serif">{item.title}</h3>
                <p>{item.excerpt}</p>
                <span class="a-foot">Lecture · {item.readingTime}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="article-newsletter" id="newsletter" data-screen-label="Newsletter">
      <div class="article-wrap">
        <div class="article-newsletter-grid">
          <div>
            <span class="sec-num">02 - Le journal, dans votre boîte</span>
            <h2 class="title">Recevez les <i class="h c-accent">repères</i> KerFlow.</h2>
            <p class="lede">
              Une fois par mois - un conseil accompagnements & soins, une idée de mouvement doux et les nouvelles de la maison.
              Jamais plus, jamais de spam.
            </p>
          </div>
          <form class="article-newsletter-form">
            <label for="article-newsletter-email">
              <span class="sr-only">Adresse e-mail</span>
              <input id="article-newsletter-email" type="email" placeholder="Votre adresse e-mail" />
            </label>
            <div class="article-newsletter-actions">
              <button class="article-newsletter-submit" type="submit">S'inscrire <span aria-hidden="true">→</span></button>
            </div>
          </form>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .article-page {
    --blog-accent: var(--clay);
    --ink-soft: #2a322c;
    background: var(--linen);
  }

  .article-wrap,
  .article-content {
    width: 100%;
    max-width: var(--site-max);
    margin-inline: auto;
    padding-inline: var(--site-pad-x);
  }

  .article-hero {
    padding-block: clamp(42px, 6vw, 84px) clamp(56px, 8vw, 104px);
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
  }

  .back-link {
    position: relative;
    display: inline-flex;
    gap: 8px;
    align-items: center;
    margin-bottom: clamp(34px, 5vw, 66px);
    color: var(--petrol-deep);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-decoration: none;
    text-transform: uppercase;
    transition: color 260ms ease, transform 300ms var(--ease-out);
  }

  .back-link::after {
    position: absolute;
    right: 0;
    bottom: -7px;
    left: 0;
    height: 1px;
    background: currentColor;
    content: "";
    transform: scaleX(1);
    transform-origin: left;
    transition: transform 360ms var(--ease-out), background 260ms ease;
  }

  .back-link span {
    display: inline-block;
    color: var(--blog-accent);
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0;
    line-height: 1;
    transform: translateY(-1px);
    transition: transform 300ms var(--ease-out);
  }

  .back-link:hover,
  .back-link:focus-visible {
    color: var(--blog-accent);
    transform: translateY(-1px);
  }

  .back-link:hover::after,
  .back-link:focus-visible::after {
    transform: scaleX(0.28);
  }

  .back-link:hover span,
  .back-link:focus-visible span {
    transform: translate(-3px, -1px);
  }

  .article-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(300px, 0.82fr);
    gap: clamp(32px, 5vw, 72px);
    align-items: end;
    justify-content: stretch;
  }

  .article-title-block {
    max-width: 840px;
  }

  .article-title-block h1,
  .related-head h2 {
    margin: 0;
    color: var(--petrol-deep);
    font-family: var(--serif);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    letter-spacing: -0.02em;
  }

  .article-title-block h1 {
    font-size: clamp(42px, 6vw, 92px);
    line-height: 1;
  }

  .kicker,
  .sec-num {
    color: var(--blog-accent);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .kicker {
    margin: 0 0 22px;
  }

  .lede {
    max-width: 720px;
    margin: clamp(24px, 3vw, 36px) 0 0;
    color: var(--ink-soft);
    font-family: var(--serif);
    font-size: clamp(19px, 1.7vw, 24px);
    font-weight: 300;
    line-height: 1.55;
  }

  .ph {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(62% 54% at 32% 30%, var(--ph-a, #5e8281) 0%, var(--ph-b, #15393b) 78%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(0, 0, 0, 0.18));
  }

  .ph::before {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(43deg, rgba(255, 255, 255, 0.07) 0 1.5px, transparent 1.5px 3px),
      repeating-linear-gradient(137deg, rgba(0, 0, 0, 0.07) 0 1.5px 3px);
    content: "";
    mix-blend-mode: overlay;
    opacity: 0.16;
  }

  .ph::after {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 52%, rgba(14, 42, 44, 0.45) 100%);
    content: "";
  }

  .ph.has-upload::before,
  .ph.has-upload::after {
    display: none;
  }

  .ph img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-photo {
    width: 100%;
    min-height: clamp(320px, 42vw, 560px);
    justify-self: stretch;
  }

  .cap {
    display: none;
    position: absolute;
    z-index: 2;
    right: 14px;
    bottom: 12px;
    left: 14px;
    color: rgba(241, 235, 225, 0.82);
    font-family: var(--mono);
    font-size: 9.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .t-storm {
    --ph-a: #5e8281;
    --ph-b: #15393b;
  }

  .t-fern {
    --ph-a: #7d9468;
    --ph-b: #2a3d22;
  }

  .t-sand {
    --ph-a: #e0c3a8;
    --ph-b: #a9784f;
  }

  .t-clay {
    --ph-a: #d99a78;
    --ph-b: #8d4f35;
  }

  .t-foam {
    --ph-a: #c9dad7;
    --ph-b: #3f6e6f;
  }

  .t-mist {
    --ph-a: #d6d8d3;
    --ph-b: #545d57;
  }

  .article-content-section {
    padding-block: var(--site-section-y);
  }

  .article-content {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    gap: clamp(36px, 5vw, 80px);
    align-items: start;
  }

  .article-toc {
    padding-top: 4px;
  }

  .article-body {
    display: flex;
    flex-direction: column;
    gap: clamp(34px, 4vw, 48px);
  }

  .article-body section {
    display: flex;
    flex-direction: column;
    gap: 16px;
    scroll-margin-top: 120px;
  }

  .article-body h2 {
    margin: 0;
    color: var(--petrol-deep);
    font-family: var(--serif);
    font-size: clamp(28px, 3vw, 42px);
    font-weight: 400;
    line-height: 1.08;
  }

  .article-body p {
    margin: 0;
    color: var(--granite);
    font-size: clamp(16px, 1.25vw, 18px);
    line-height: 1.78;
  }

  .rule-top {
    border-top: 1px solid var(--rule);
  }

  .band-paper {
    background: var(--paper);
  }

  .related-section {
    padding-block: var(--site-section-y);
  }

  .article-newsletter {
    padding-block: var(--site-section-y);
    border-top: 1px solid var(--rule);
    background: var(--linen);
  }

  .article-newsletter-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
    gap: clamp(36px, 5vw, 80px);
    align-items: center;
  }

  .article-newsletter .title {
    max-width: 820px;
    margin: 16px 0 0;
    color: var(--petrol-deep);
    font-family: var(--serif);
    font-size: clamp(34px, 5vw, 64px);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    line-height: 1.03;
    letter-spacing: -0.02em;
  }

  .article-newsletter .title i {
    color: var(--blog-accent);
    font-style: italic;
    font-weight: 300;
  }

  .article-newsletter .lede {
    margin-top: 22px;
    color: var(--ink-soft);
  }

  .article-newsletter-form {
    display: grid;
    gap: 24px;
    max-width: 520px;
    margin: 0;
  }

  .article-newsletter-form label {
    border-bottom: 1px solid color-mix(in srgb, var(--petrol-deep) 24%, transparent);
    transition: border-color 260ms ease;
  }

  .article-newsletter-form label:focus-within {
    border-color: var(--blog-accent);
  }

  .article-newsletter-form input {
    width: 100%;
    border: 0;
    background: transparent;
    color: var(--petrol-deep);
    font-family: var(--sans);
    font-size: 15px;
    outline: 0;
    padding: 12px 0;
  }

  .article-newsletter-form input::placeholder {
    color: var(--granite-500);
    transition: color 260ms ease;
  }

  .article-newsletter-form label:focus-within input::placeholder {
    color: color-mix(in srgb, var(--blog-accent) 72%, transparent);
  }

  .article-newsletter-submit {
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    gap: 10px;
    border: 0;
    background: var(--clay);
    color: var(--linen);
    cursor: pointer;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    padding: 0 22px;
    text-transform: uppercase;
    transition: background 260ms ease, transform 300ms var(--ease-out), box-shadow 300ms var(--ease-out);
  }

  .article-newsletter-submit:hover,
  .article-newsletter-submit:focus-visible {
    background: var(--petrol-deep);
    box-shadow: 0 14px 26px rgba(14, 42, 44, 0.16);
    transform: translateY(-2px);
  }

  .article-newsletter-submit:focus-visible {
    outline: 2px solid var(--petrol-deep);
    outline-offset: 3px;
  }

  .related-head {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: clamp(28px, 3vw, 40px);
  }

  .related-head h2 {
    font-size: clamp(34px, 5vw, 64px);
    line-height: 1.03;
  }

  .related-head i {
    color: var(--blog-accent);
    font-style: italic;
    font-weight: 300;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(16px, 2.2vw, 24px);
  }

  .art {
    display: flex;
    overflow: hidden;
    flex-direction: column;
    border: 1px solid var(--rule);
    background: var(--paper);
    color: inherit;
    text-decoration: none;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .art:hover,
  .art:focus-visible {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px -28px rgba(14, 42, 44, 0.5);
  }

  .art .ph {
    width: 100%;
    aspect-ratio: 3 / 2;
  }

  .a-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 13px;
    padding: clamp(24px, 2.4vw, 32px);
  }

  .a-tag {
    color: var(--blog-accent);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .art h3 {
    margin: 0;
    color: var(--petrol-deep);
    font-size: clamp(20px, 1.8vw, 24px);
    font-weight: 400;
    line-height: 1.12;
  }

  .art p {
    margin: 0;
    color: var(--granite-500);
    font-size: 14px;
    line-height: 1.62;
  }

  .a-foot {
    margin-top: auto;
    padding-top: 18px;
    border-top: 1px solid var(--rule-soft);
    color: var(--granite-500);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .article-hero-grid,
    .article-content,
    .article-newsletter-grid,
    .related-grid {
      grid-template-columns: 1fr;
    }

    .article-toc {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 8px;
      padding-top: 0;
    }

    .article-toc a {
      border: 1px solid var(--rule);
      padding: 8px 13px;
    }
  }

  @media (max-width: 640px) {
    .article-photo {
      min-height: 280px;
    }

    .art {
      min-height: 0;
    }
  }
</style>
