      .cta-band h2{ font-family:var(--serif); font-weight:400; font-size:clamp(30px,4vw,56px); line-height:1.03; letter-spacing:-0.02em; margin:0; color:var(--linen); font-variation-settings:"opsz" 144; }
      .cta-band h2 i{ font-style:italic; font-weight:300; color:var(--clay-light); }
      .cta-band p{ font-size:16px; line-height:1.6; color:rgba(241,235,225,0.78); margin:0 0 24px; max-width:420px; }
      .cta-band .cta-actions{ display:flex; gap:16px; flex-wrap:wrap; align-items:center; }
      @media (max-width:820px){ .cta-band .wrap{ grid-template-columns:1fr; } }
      
      /* =========================================================
         FILET DE SECTION compact (eyebrow + titre simple)
         ========================================================= */
