      .radio-chip span{ display:inline-block; font-family:var(--mono); font-size:10.5px; letter-spacing:0.16em; text-transform:uppercase; color:var(--granite); border:1px solid var(--rule); padding:10px 16px; transition:.2s; cursor:pointer; }
      .radio-chip input:checked + span{ border-color:var(--accent-ink); color:var(--accent-ink); background:var(--accent-soft); }
      .form-foot{ display:flex; align-items:center; justify-content:space-between; gap:20px; flex-wrap:wrap; margin-top:clamp(24px,3vw,36px); }
      .form-foot .fine{ font-size:12.5px; color:var(--granite); max-width:380px; }
      @media (max-width:680px){ .form-grid{ grid-template-columns:1fr; } }
      
      /* =========================================================
