---
// Page rebuilt from /Users/evadegardin/Downloads/Le lieu - KerFlow (standalone).html
import SiteHeader from "../components/SiteHeader.astro";
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Le lieu · KerFlow · Maison de prévention-santé · Clamart</title>
    <meta name="description" content="Découvrir KerFlow, maison de prévention-santé et de mieux-être à Clamart : espaces, ambiance, histoire et approche." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500&family=Manrope:wght@300;400;500;600;700&family=Pinyon+Script&display=swap" rel="stylesheet" />
    <style is:inline>
      /* =========================================================
         KERFLOW — Home page finale · feuille de style figée
         Direction : A / Maison (base) + entrées B + cours C/B clairs
         Palette Galet (Pierre & Mer) + accents services
         ========================================================= */
      
      :root{
        /* — Palette principale : Galet / Pierre & Mer — */
        --petrol:        #1c4244;   /* couleur du mot KerFlow + primaire */
        --petrol-deep:   #0e2a2c;   /* fonds foncés (charte, footer) */
        --petrol-mid:    #2f6a6c;
        --linen:         #f1ebe1;   /* fond clair principal */
        --paper:         #faf6ee;
        --bone:          #f6f2e8;
        --ink:           #1f2622;
        --ink-soft:      #2a322c;
        --granite:       #545d57;
        --granite-300:   #98a09a;
        --clay:          #a05a3a;   /* terre, accent chaud — usage rare */
        --clay-light:    #d99a78;
      
        /* — Couleurs services (accents : cartes, encadrements, pastilles) — */
        --studio:        #d4dcc6;   --studio-ink:   #4f6b3c;   --studio-mid: #8aa074;
        --consult:       #c9dad7;   --consult-ink:  #2f6a6c;
        --rituel:        #ecd7c8;   --rituel-ink:   #a05a3a;
        --ateliers:      #d6d8d3;   --ateliers-ink: #545d57;
      
        --rule:        rgba(31,38,34,0.14);
        --rule-soft:   rgba(31,38,34,0.08);
        --rule-light:  rgba(241,235,225,0.16);
      
        /* — Type — */
        --serif:  "Fraunces", Georgia, serif;
        --sans:   "Manrope", system-ui, sans-serif;
        --mono:   "DM Mono", ui-monospace, monospace;
        --script: "Pinyon Script", cursive;
      
        /* — Mesures fluides — */
        --site-max: 1440px;
        --site-pad-x: clamp(20px, 6vw, 88px);
        --site-section-y: clamp(72px, 8vw, 112px);
        --site-header-y: 22px;
        --pad-x:  var(--site-pad-x);
        --gap:    clamp(16px, 2.2vw, 24px);
        --maxw:   var(--site-max);
        --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
      
        --t-hero:    clamp(40px, 5.8vw, 92px);
        --t-h2:      clamp(34px, 5.4vw, 72px);
        --t-h3:      clamp(24px, 2.6vw, 34px);
        --t-card:    clamp(22px, 2vw, 30px);
      }
      
      *,*::before,*::after{ box-sizing:border-box; }
      html{ scroll-behavior:smooth; -webkit-text-size-adjust:100%; }
      body{
        margin:0; background:var(--linen); color:var(--petrol-deep);
        font-family:var(--sans); font-size:16px; line-height:1.6;
        -webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility;
        overflow-x:hidden;
      }
      img{ max-width:100%; display:block; }
      a{ color:inherit; }
      sup{ font-size:0.58em; vertical-align:super; }
      
      /* ---------- Helpers type ---------- */
      .serif{ font-family:var(--serif); font-weight:400; font-variation-settings:"opsz" 144; }
      .eyebrow{
        font-family:var(--mono); font-size:11px; letter-spacing:0.24em;
        text-transform:uppercase; color:var(--clay); font-weight:500;
      }
      .eyebrow.muted{ color:var(--granite); }
      .mono{ font-family:var(--mono); font-size:11px; letter-spacing:0.2em; text-transform:uppercase; }
      .lede{ font-family:var(--serif); font-weight:300; font-size:clamp(19px,1.7vw,23px); line-height:1.5; color:var(--ink); }
      i.h{ font-style:italic; }
      .c-petrol{ color:var(--clay); }
      .c-brand-petrol{ color:var(--petrol); }
      .c-clay{ color:var(--clay); }
      .c-studio{ color:var(--studio-ink); }
      .c-consult{ color:var(--consult-ink); }
      .c-rituel{ color:var(--rituel-ink); }
      
      /* ---------- Layout ---------- */
      .wrap{ max-width:var(--maxw); margin:0 auto; padding-inline:var(--pad-x); }
      section{ position:relative; }
      .section-pad{ padding-block:var(--site-section-y); }
      .wrapped-sections > section.section-pad{ padding-inline:0; }
      .rule-top{ border-top:1px solid var(--rule); }
      
      .sec-head{ display:flex; flex-direction:column; gap:18px; max-width:920px; }
      .sec-num{ font-family:var(--mono); font-size:11px; letter-spacing:0.24em; text-transform:uppercase; color:var(--clay); }
      h2.title{
        font-family:var(--serif); font-weight:400; font-size:var(--t-h2);
        line-height:1.03; letter-spacing:-0.02em; margin:0; font-variation-settings:"opsz" 144;
      }
      h3.sub{ font-family:var(--serif); font-weight:400; font-size:var(--t-h3); line-height:1.06; margin:0; letter-spacing:-0.015em; font-variation-settings:"opsz" 144; }
      
      /* ---------- Logo lockup KerFlow + tag ---------- */
      .kf-lock{ display:inline-flex; flex-direction:column; align-items:flex-start; line-height:0.9; }
      .kf-lock .word{
        font-family:var(--serif); font-weight:500; letter-spacing:-0.02em; line-height:1;
        font-size:var(--lock-size,22px); color:var(--lock-color,var(--petrol)); font-variation-settings:"opsz" 144;
      }
      .kf-lock .tag{
        font-family:var(--script); font-size:calc(var(--lock-size,22px) * 0.82);
        color:var(--lock-tag, var(--lock-color, var(--petrol))); line-height:0.8;
        margin-top:calc(var(--lock-size,22px) * -0.02); padding-left:calc(var(--lock-size,22px) * 0.12);
      }
      .kf-lock.row{ flex-direction:row; align-items:baseline; gap:0.5em; }
      .kf-lock.row .tag{ margin-top:0; }
      
      /* ---------- Boutons ---------- */
      .btn{
        position:relative; overflow:hidden;
        font-family:var(--sans); font-weight:500; font-size:14px; letter-spacing:0.02em;
        display:inline-flex; align-items:center; gap:11px; cursor:pointer; border:0;
        padding:15px 26px; text-decoration:none; border-radius:0;
        transition:background 260ms ease, color 260ms ease, transform 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)), box-shadow 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1));
      }
      .btn svg{ width:16px; height:16px; }
      .btn-primary{ background:var(--petrol); color:var(--linen); }
      .btn-primary:hover,.btn-primary:focus-visible{ background:var(--clay); transform:translateY(-2px); box-shadow:0 14px 26px rgba(14,42,44,0.16); }
      .btn-light{ background:var(--linen); color:var(--petrol-deep); }
      .btn-light:hover{ background:#fff; }
      .btn-line{
        position:relative;
        display:inline-flex;
        align-items:center;
        justify-content:center;
        min-height:46px;
        font-family:var(--mono); font-size:11px; letter-spacing:0.22em; text-transform:uppercase;
        background:transparent; color:var(--petrol-deep); padding:11px 0; gap:10px;
        border-bottom:1px solid transparent;
        cursor:pointer;
        text-decoration:none;
        transition:color 260ms ease, transform 300ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1));
      }
      .btn-line::after{
        content:"";
        position:absolute;
        right:0;
        bottom:4px;
        left:0;
        height:1px;
        background:currentColor;
        transform:scaleX(1);
        transform-origin:left;
        transition:transform 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)), background 260ms ease;
      }
      .btn-line:hover,.btn-line:focus-visible{ color:var(--clay); transform:translateY(-1px); }
      .btn-line:hover::after,.btn-line:focus-visible::after{ transform:scaleX(0.28); }
      .btn-line.on-dark{ color:var(--linen); }
      .btn-ghost{
        font-family:var(--mono); font-size:11px; letter-spacing:0.22em; text-transform:uppercase;
        background:transparent; color:var(--petrol); border:1px solid var(--rule); padding:13px 22px;
      }
      .btn-ghost:hover{ border-color:var(--petrol); }
      
      /* ---------- Icône trait fin ---------- */
      .ic{ width:22px; height:22px; stroke:currentColor; stroke-width:1.5; fill:none;
        stroke-linecap:round; stroke-linejoin:round; flex:none; }
      
      /* ---------- Placeholder photo ---------- */
      .ph{
        position:relative; overflow:hidden; background:var(--ph-a,#3b6c6e);
        background-image:
          radial-gradient(62% 54% at 32% 30%, var(--ph-a,#3b6c6e) 0%, var(--ph-b,#0e2a2c) 78%),
          linear-gradient(180deg, rgba(255,255,255,0.05), rgba(0,0,0,0.18));
      }
      .ph::before{ /* grain */
        content:""; position:absolute; inset:0; opacity:0.16; mix-blend-mode:overlay;
        background:
          repeating-linear-gradient(43deg, rgba(255,255,255,0.07) 0 1.5px, transparent 1.5px 3px),
          repeating-linear-gradient(137deg, rgba(0,0,0,0.07) 0 1.5px, transparent 1.5px 3px);
      }
      .ph::after{ /* dégradé bas */
        content:""; position:absolute; inset:0;
        background:linear-gradient(180deg, transparent 52%, rgba(14,42,44,0.45) 100%);
      }
      .ph .cap{
        position:absolute; left:14px; right:14px; bottom:12px; z-index:2;
        font-family:var(--mono); font-size:9.5px; letter-spacing:0.16em; text-transform:uppercase;
        color:rgba(241,235,225,0.82);
      }
      /* tonalités nature */
      .t-petrol { --ph-a:#3b6c6e; --ph-b:#0e2a2c; }
      .t-storm  { --ph-a:#5e8281; --ph-b:#15393b; }
      .t-foam   { --ph-a:#9bbab8; --ph-b:#3f6e6f; }
      .t-fern   { --ph-a:#7d9468; --ph-b:#2a3d22; }
      .t-fern-d { --ph-a:#5f7a4a; --ph-b:#23331b; }
      .t-clay   { --ph-a:#c47a55; --ph-b:#6b3d29; }
      .t-sand   { --ph-a:#e0c3a8; --ph-b:#a9784f; }
      .t-stone  { --ph-a:#b9bcb2; --ph-b:#6f7268; }
      .t-linen  { --ph-a:#e8dfd0; --ph-b:#a59882; }
      
      /* encadrement coloré autour des photos */
      .framed{ padding:10px; background:var(--frame,var(--rituel)); }
      .framed .ph{ width:100%; height:100%; }
      
      /* ---------- Carte générique ---------- */
      .card{ background:var(--paper); border:1px solid var(--rule); display:flex; flex-direction:column; }
      .card .body{ padding:clamp(22px,2vw,30px); display:flex; flex-direction:column; gap:14px; flex:1; }
      .card .foot{
        margin-top:auto; padding-top:16px; border-top:1px solid var(--rule-soft);
        display:flex; justify-content:space-between; align-items:baseline;
        font-family:var(--mono); font-size:10.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--granite);
      }
      .card .foot a{ text-decoration:none; color:var(--petrol); }
      .card p{ margin:0; font-size:14.5px; line-height:1.6; color:var(--granite); }
      
      /* link arrow */
      .lnk{ font-family:var(--mono); font-size:11px; letter-spacing:0.2em; text-transform:uppercase;
        text-decoration:none; display:inline-flex; align-items:center; gap:9px; }
      
      /* =========================================================
         HEADER
         ========================================================= */
      .site-head{
        position:sticky; top:0; z-index:50;
        background:rgba(241,235,225,0.85); backdrop-filter:blur(14px) saturate(1.05);
        border-bottom:1px solid var(--rule-soft);
      }
      .site-head .bar{ display:flex; align-items:center; justify-content:space-between; gap:24px; padding-block:18px; }
      .site-head nav ul{ list-style:none; display:flex; gap:clamp(20px,2.4vw,38px); margin:0; padding:0; }
      .site-head nav a{ text-decoration:none; color:var(--petrol-deep); font-size:14px; letter-spacing:0.01em; white-space:nowrap; }
      .site-head nav a:hover{ color:var(--clay); }
      .head-cta{ display:flex; align-items:center; gap:18px; }
      .burger{ display:none; background:none; border:0; cursor:pointer; padding:6px; }
      .burger svg{ width:26px; height:26px; stroke:var(--petrol-deep); stroke-width:1.5; }

      .site-header{
        position:sticky; top:0; z-index:50;
        display:flex; align-items:center; justify-content:space-between; gap:28px;
        padding:var(--site-header-y) var(--site-pad-x);
        background:rgba(241,235,225,0.88); backdrop-filter:blur(14px) saturate(1.05);
        border-bottom:1px solid var(--rule-soft);
      }
      .brand{ display:inline-flex; align-items:baseline; gap:10px; flex:0 0 auto; color:var(--petrol); text-decoration:none; }
      .brand:hover,.brand:focus-visible{ color:var(--clay); }
      .brand-word{ font-family:var(--serif); font-size:20px; line-height:1; letter-spacing:-0.018em; font-variation-settings:"opsz" 144; }
      .brand-divider{ width:1px; height:12px; background:currentColor; opacity:0.35; }
      .brand-tag{ font-family:var(--mono); font-size:8px; letter-spacing:0.32em; text-transform:uppercase; opacity:0.7; }
      .main-nav{ display:flex; gap:clamp(14px,2.5vw,36px); align-items:center; font-size:13.5px; letter-spacing:0.02em; white-space:nowrap; }
      .main-nav a,.nav-trigger{ position:relative; border:0; padding:0; background:transparent; color:var(--petrol-deep); cursor:pointer; list-style:none; text-decoration:none; transition:color 240ms ease; }
      .nav-trigger::-webkit-details-marker{ display:none; }
      .main-nav a::after,.nav-trigger::after{
        content:""; position:absolute; right:0; bottom:-5px; left:0; height:1px;
        background:currentColor; transform:scaleX(0); transform-origin:right; transition:transform 260ms ease;
      }
      .main-nav a:hover,.main-nav a:focus-visible,.nav-trigger:hover,.nav-trigger:focus-visible{ color:var(--clay); }
      .main-nav a:hover::after,.main-nav a:focus-visible::after,.nav-trigger:hover::after,.nav-trigger:focus-visible::after{ transform:scaleX(1); transform-origin:left; }
      .nav-item{ position:relative; }
      .nav-submenu{
        position:absolute; top:calc(100% + 16px); left:50%; min-width:230px; padding:10px;
        border:1px solid var(--rule-soft); background:rgba(250,246,238,0.96);
        box-shadow:0 18px 34px rgba(14,42,44,0.12);
        opacity:0; pointer-events:none; transform:translateX(-50%) translateY(8px);
        transition:opacity 220ms ease, transform 260ms ease; visibility:hidden;
      }
      .nav-submenu::before{ content:""; position:absolute; right:0; bottom:100%; left:0; height:16px; }
      .has-submenu:hover .nav-submenu,.has-submenu[open] .nav-submenu,.has-submenu:focus-within .nav-submenu{ opacity:1; pointer-events:auto; transform:translateX(-50%) translateY(0); visibility:visible; }
      .nav-submenu a{ display:flex; flex-direction:column; gap:2px; padding:11px 12px; }
      .nav-submenu a:hover,.nav-submenu a:focus-visible{ background:var(--bone); }
      .nav-submenu a::after{ display:none; }
      .nav-submenu span{ color:var(--granite); font-family:var(--mono); font-size:9px; letter-spacing:0.16em; text-transform:uppercase; }
      .reserve-link{
        flex:0 0 auto; padding:12px 20px; background:var(--petrol); color:var(--linen);
        font-family:var(--mono); font-size:11px; letter-spacing:0.22em; text-transform:uppercase;
        text-decoration:none; transition:background 260ms ease, color 260ms ease, transform 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1)), box-shadow 360ms var(--ease-out, cubic-bezier(0.22, 1, 0.36, 1));
      }
      .reserve-link:hover,.reserve-link:focus-visible{ background:var(--clay); transform:translateY(-2px); box-shadow:0 14px 26px rgba(14,42,44,0.16); }
      @media (max-width:1180px){ .main-nav{ display:none; } }
      @media (max-width:760px){
        .site-header{ align-items:flex-start; }
        .reserve-link{ padding:10px 14px; font-size:10px; }
      }
      
      /* =========================================================
         HERO
         ========================================================= */
      .hero{ display:grid; min-height:calc(100vh - 83px); min-height:calc(100svh - 83px); align-content:center; padding-top:clamp(40px,6vw,76px); }
      .hero .topline{
        display:flex; justify-content:space-between; gap:16px;
        font-family:var(--mono); font-size:11px; letter-spacing:0.22em; text-transform:uppercase;
        color:var(--granite); margin-bottom:clamp(36px,5vw,64px); flex-wrap:wrap;
      }
      .hero-grid{ display:grid; grid-template-columns:1.7fr 1fr; gap:clamp(32px,5vw,72px); align-items:end; }
      .hero h1{
        font-family:var(--serif); font-weight:400; font-size:var(--t-hero);
        line-height:1.0; letter-spacing:-0.026em; margin:0; font-variation-settings:"opsz" 144;
      }
      .hero h1 i{ font-weight:300; }
      .hero-cta{ display:flex; gap:16px; align-items:center; margin-top:clamp(32px,4vw,52px); flex-wrap:wrap; }
      .hero-aside .lede{ max-width:400px; }
      .hero-tags{ display:flex; flex-wrap:wrap; gap:8px; margin-top:24px; }
      .hero-tags span{
        font-family:var(--mono); font-size:10px; letter-spacing:0.2em; text-transform:uppercase;
        color:var(--granite); border:1px solid var(--rule); padding:6px 11px;
      }
      
      /* galerie défilante */
      .gallery{ margin-top:clamp(40px,6vw,80px); position:relative; }
      .gallery-head{ display:flex; justify-content:space-between; align-items:baseline; margin-bottom:16px; flex-wrap:wrap; gap:10px; }
      .gallery-track-mask{ overflow:hidden; }
      .gallery-track{ display:flex; gap:16px; width:max-content; animation:slide 46s linear infinite; }
      .gallery:hover .gallery-track{ animation-play-state:paused; }
      .gallery-track .ph{ width:clamp(240px,28vw,380px); aspect-ratio:4/5; flex:none; }
      .gallery-track .ph.wide{ width:clamp(360px,40vw,560px); aspect-ratio:16/10; }
      @keyframes slide{ from{ transform:translateX(0); } to{ transform:translateX(-50%); } }
      @media (prefers-reduced-motion:reduce){ .gallery-track{ animation:none; } }
      
      /* =========================================================
         SECTION 2 — Ker / Flow
         ========================================================= */
      .kerflow-split{ display:grid; grid-template-columns:1fr 1fr; gap:clamp(32px,5vw,80px); align-items:start; }
      .kerflow-def{ display:grid; gap:28px; }
      .def-row{ display:grid; grid-template-columns:auto 1fr; gap:28px; align-items:baseline; padding-bottom:24px; border-bottom:1px solid var(--rule-soft); }
      .def-row .big{ font-family:var(--serif); font-style:italic; font-size:clamp(40px,5vw,68px); line-height:1; color:var(--petrol); font-variation-settings:"opsz" 144; }
      .def-row .big.clay{ color:var(--clay); }
      .def-row p{ margin:0; font-size:15.5px; line-height:1.6; color:var(--granite); }
      
      /* =========================================================
         SECTION 3 — Prendre soin de soi
         ========================================================= */
      .besoins{ display:grid; grid-template-columns:repeat(3,1fr); gap:0; border-top:1px solid var(--rule); margin-top:clamp(40px,5vw,64px); }
      .besoin{ padding:34px clamp(20px,2vw,34px) 30px; border-bottom:1px solid var(--rule); display:flex; flex-direction:column; gap:14px; }
      .besoin:not(:last-child){ border-right:1px solid var(--rule); }
      .besoin .n{ font-family:var(--mono); font-size:11px; letter-spacing:0.2em; color:var(--clay); }
      .besoin h3{ font-family:var(--serif); font-weight:400; font-size:clamp(26px,2.4vw,34px); margin:0; line-height:1.04; font-variation-settings:"opsz" 144; }
      .besoin p{ margin:0; font-size:14.5px; line-height:1.6; color:var(--granite); }
      
      /* portes KerFlow */
      .portes-head{ display:flex; justify-content:space-between; align-items:flex-end; gap:24px; flex-wrap:wrap; margin:clamp(64px,8vw,104px) 0 clamp(28px,3vw,40px); }
      .portes{ display:grid; grid-template-columns:repeat(4,1fr); gap:var(--gap); }
      .porte{
        position:relative; display:flex; flex-direction:column; gap:18px;
        background:var(--p-bg); border:1px solid var(--rule); padding:32px 28px 28px; min-height:330px;
        text-decoration:none; transition:transform .3s, box-shadow .3s;
      }
      .porte:hover{ transform:translateY(-4px); box-shadow:0 18px 40px -28px rgba(14,42,44,0.5); }
      .porte .door-num{ font-family:var(--mono); font-size:10px; letter-spacing:0.22em; text-transform:uppercase; color:var(--p-ink); opacity:0.75; }
      .porte .desc{ font-size:13.5px; line-height:1.55; color:var(--ink-soft); flex:1; }
      .porte .role{ font-family:var(--mono); font-size:10px; letter-spacing:0.2em; text-transform:uppercase; color:var(--p-ink); }
      .porte .door-foot{ display:flex; align-items:center; gap:9px; font-family:var(--mono); font-size:10.5px; letter-spacing:0.2em; text-transform:uppercase; color:var(--p-ink); padding-top:14px; border-top:1px solid var(--rule-soft); }
      
      /* =========================================================
         SECTION 4 — Espaces (mosaïque, Salle plus grande)
         ========================================================= */
      .espaces{ display:grid; grid-template-columns:1.55fr 1fr 1fr; grid-template-rows:auto auto; gap:var(--gap); margin-top:clamp(36px,4vw,56px); }
      .espace{ overflow:hidden; background:var(--paper); border:1px solid var(--rule); display:flex; flex-direction:column; }
