         ========================================================= */
      .contact-grid{ display:grid; grid-template-columns:1fr 1.2fr; gap:clamp(36px,5vw,72px); align-items:start; }
      .coord-list{ display:grid; gap:0; border-top:1px solid var(--rule); }
