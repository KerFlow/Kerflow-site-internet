  <body class="page wrapped-sections">
    <SiteHeader />
    
    <!-- ===================== HERO ===================== -->
    <section class="page-hero wrap" data-screen-label="Le lieu · Hero">
      <div class="page-hero-grid">
        <div>
          <p class="kicker">La maison KerFlow · Clamart</p>
          <h1 class="serif">
            Un endroit pour<br>
            <i class="h-accent">bouger, respirer,</i><br>
            comprendre et<br>
            prendre soin de soi.
          </h1>
          <div class="hero-cta">
