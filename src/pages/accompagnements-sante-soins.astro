---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { peopleForSpace } from "../data/cmsContent.js";

const bullePeople = peopleForSpace("la-bulle");
const coconPeople = peopleForSpace("le-cocon");
---

<BaseLayout
  title="Accompagnements & Soins - KerFlow"
  description="Consultations d'accompagnements & soins, NAPSOtherapie, sommeil, alimentation, stress, massages et soins corporels a Clamart."
>
  <SiteHeader />
  <main>
    <section class="page-hero section-pad accent-consult">
      <div>
        <p class="eyebrow">Accompagnements & Soins</p>
        <h1>Prendre soin de soi <em>autrement</em>.</h1>
      </div>
      <div>
        <div class="service-mark">
          <img src="/assets/logos/kerflow-consult-web.png" width="1200" height="829" alt="KerFlow Consult" loading="eager" decoding="async" />
        </div>
        <p>Deux espaces complementaires : La Bulle pour les accompagnements & soins, Le Cocon pour les soins corporels.</p>
        <div class="actions">
          <a class="btn btn-primary" href="/contact/">Prendre rendez-vous <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    <section class="section-pad soft-band">
      <div class="page-card-grid two">
        <article id="la-bulle" class="page-card accent-consult">
          <p class="mini">La Bulle</p>
          <h3>Accompagnements & soins</h3>
          <p>Consultations autour de l'alimentation, du sommeil, de l'activite physique, du stress, du bien-etre mental et des comportements de sante.</p>
          <ul>
            <li>NAPSOtherapie integree aux consultations</li>
            <li>Sommeil et recuperation</li>
            <li>Alimentation sans culpabilite</li>
            <li>Stress et equilibre du quotidien</li>
          </ul>
        </article>
        <article id="le-cocon" class="page-card accent-rituel">
          <p class="mini">Le Cocon</p>
          <h3>Soins du corps</h3>
          <p>Massages, drainage lymphatique, reflexologie, acupuncture et soins corporels pour ralentir, recuperer et relacher.</p>
          <ul>
            <li>Massages et relaxation</li>
            <li>Drainage lymphatique</li>
            <li>Reflexologie</li>
            <li>Soins corporels par praticiens qualifies</li>
          </ul>
        </article>
      </div>
    </section>

    <section id="intervenants" class="page-section section-pad">
      <div class="content-split">
        <div>
          <p class="eyebrow">Intervenants</p>
          <h2>Des fiches claires,<br /><em>a completer</em>.</h2>
        </div>
        <div class="body-copy">
          <p>Chaque praticien aura une fiche avec sa specialite, son approche, sa photo et ses liens utiles. L'objectif est d'aider a choisir sans mettre toutes les pratiques sur le meme plan.</p>
          <p>La Bulle regroupe les consultations d'accompagnements & soins. Le Cocon regroupe les pratiques corporelles.</p>
        </div>
      </div>
      <div class="page-card-grid two">
        {bullePeople.map((person) => (
          <article class="page-card accent-consult">
            <p class="mini">La Bulle</p>
            <h3>{person.name}</h3>
            <p><strong>{person.specialty}</strong></p>
            <p>{person.bio}</p>
            <a href={person.primaryLinkUrl}>{person.primaryLinkLabel}</a>
          </article>
        ))}
        {coconPeople.map((person) => (
          <article class="page-card accent-rituel">
            <p class="mini">Le Cocon</p>
            <h3>{person.name}</h3>
            <p><strong>{person.specialty}</strong></p>
            <p>{person.bio}</p>
            <a href={person.primaryLinkUrl}>{person.primaryLinkLabel}</a>
          </article>
        ))}
      </div>
    </section>

    <section class="page-section section-pad deep">
      <div class="section-head two">
        <div>
          <p class="eyebrow">Reservation</p>
          <h2>Un parcours <em>simple</em>.</h2>
        </div>
        <p>La page doit permettre de choisir entre accompagnement et soin, puis de contacter le bon praticien ou d'acceder au lien de reservation.</p>
      </div>
      <div class="page-card-grid">
        <article class="page-card accent-consult"><h3>1. Choisir</h3><p>Accompagnements & soins ou soin corporel.</p></article>
        <article class="page-card accent-location"><h3>2. Comprendre</h3><p>Lire l'approche, la duree et le type de rendez-vous.</p></article>
        <article class="page-card accent-rituel"><h3>3. Reserver</h3><p>Passer par le lien direct ou le formulaire de contact.</p></article>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
