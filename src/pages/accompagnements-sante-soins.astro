---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { peopleForSpace } from "../data/cmsContent.js";

const bullePeople = peopleForSpace("la-bulle");
const coconPeople = peopleForSpace("le-cocon");
---

<BaseLayout
  title="Accompagnements & Soins - KerFlow"
  description="Accompagnements & soins, NAPSOtherapie, sommeil, alimentation, stress, massages et soins corporels a Clamart."
>
  <SiteHeader />
  <main>
    <section class="page-hero section-pad accent-consult">
      <div>
        <p class="eyebrow">Accompagnements & Soins</p>
        <h1>Prendre soin de soi <em>autrement</em>.</h1>
      </div>
      <div>
        <div class="service-mark">
          <img src="/assets/logos/kerflow-consult-web.png" width="1200" height="829" alt="KerFlow Consult" loading="eager" decoding="async" />
        </div>
        <p>Deux espaces complémentaires : La Bulle pour les accompagnements, Le Cocon pour les soins corporels.</p>
        <div class="actions">
          <a class="btn btn-primary" href="/le-lieu/#espaces">Découvrir nos espaces <span aria-hidden="true">→</span></a>
        </div>
      </div>
    </section>

    <section class="section-pad soft-band">
      <div class="page-card-grid two">
        <article id="la-bulle" class="page-card accent-consult">
          <img class="service-card-logo" src="/assets/logos/kerflow-consult-web.png" width="1200" height="829" alt="KerFlow Consult" loading="lazy" decoding="async" />
          <p class="mini">La Bulle</p>
          <h3>Accompagnement</h3>
          <p>Des consultations individuelles pour être accompagné sur des sujets liés à la prévention santé et au mieux-être : alimentation, sommeil, gestion du stress, équilibre de vie ou santé de la femme.</p>
          <ul>
            <li>Napsothérapie</li>
            <li>Diététique</li>
            <li>Naturopathie</li>
            <li>Sophrologie</li>
          </ul>
        </article>
        <article id="le-cocon" class="page-card accent-rituel">
          <img class="service-card-logo" src="/assets/logos/kerflow-rituel-web.png" width="1200" height="829" alt="KerFlow Rituel" loading="lazy" decoding="async" />
          <p class="mini">Le Cocon</p>
          <h3>Soins du corps</h3>
          <p>Des soins manuels pour prendre soin de son corps : massages bien-être, massage prénatal, drainage lymphatique manuel, fasciathérapie et autres pratiques proposées par nos praticiens.</p>
          <ul>
            <li>Massage bien-être</li>
            <li>Massage prénatal</li>
            <li>Drainage lymphatique</li>
            <li>Fasciathérapie</li>
          </ul>
        </article>
      </div>
    </section>

    <section id="intervenants" class="page-section section-pad">
      <div class="content-split">
        <div>
          <p class="eyebrow">02 - Les intervenants</p>
          <h2>Des praticien·nes<br /><em>à choisir.</em></h2>
        </div>
        <div class="body-copy">
          <p>Chaque praticien·ne possède sa propre spécialité et sa propre approche. Nous les avons choisi·es pour leur professionnalisme, leur expérience et leur sens de l'écoute.</p>
          <p>Les fiches sont gérées dans le CMS, avec une option de visibilité pour masquer un profil sans le supprimer.</p>
        </div>
      </div>
      <div class="page-card-grid two">
        {bullePeople.map((person) => (
          <article class="page-card accent-consult">
            <img class="service-card-logo service-card-logo-small" src="/assets/logos/kerflow-consult-web.png" width="1200" height="829" alt="KerFlow Consult" loading="lazy" decoding="async" />
            <p class="mini">À La Bulle · accompagnement</p>
            <h3>{person.name}</h3>
            <p><strong>{person.specialty}</strong></p>
            <p>{person.bio}</p>
            <a href={person.primaryLinkUrl}>{person.primaryLinkLabel}</a>
          </article>
        ))}
        {coconPeople.map((person) => (
          <article class="page-card accent-rituel">
            <img class="service-card-logo service-card-logo-small" src="/assets/logos/kerflow-rituel-web.png" width="1200" height="829" alt="KerFlow Rituel" loading="lazy" decoding="async" />
            <p class="mini">Au Cocon · soin du corps</p>
            <h3>{person.name}</h3>
            <p><strong>{person.specialty}</strong></p>
            <p>{person.bio}</p>
            <a href={person.primaryLinkUrl}>{person.primaryLinkLabel}</a>
          </article>
        ))}
      </div>
    </section>

    <section class="page-section section-pad deep">
      <div class="section-head two">
        <div>
          <p class="eyebrow">03 - Comment réserver</p>
          <h2>Choisir un <em>accompagnement ou un soin</em>.</h2>
        </div>
        <p>Vous choisissez, vous prenez rendez-vous, on vous accueille.</p>
      </div>
      <div class="page-card-grid">
        <article class="page-card accent-consult"><h3>Vous choisissez</h3><p>Découvrez les différents accompagnements et soins, puis choisissez le professionnel qui correspond le mieux à vos besoins.</p></article>
        <article class="page-card accent-location"><h3>Vous prenez rendez-vous</h3><p>Prenez directement contact avec le professionnel de votre choix pour convenir d'un rendez-vous.</p></article>
        <article class="page-card accent-rituel"><h3>On vous accueille</h3><p>Présentez-vous quelques minutes avant votre rendez-vous. Installez-vous confortablement à la tisanerie : on viendra vous chercher dès que possible.</p></article>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .service-card-logo {
    display: block;
    width: min(190px, 62%);
    height: auto;
    margin-bottom: 18px;
  }

  .service-card-logo-small {
    width: min(150px, 54%);
    margin-bottom: 14px;
  }
</style>
