---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteVisual from "../../components/SiteVisual.astro";
import { peopleForSpace } from "../../data/cmsContent.js";
import { siteVisuals } from "../../data/siteVisuals.js";

const practitioners = peopleForSpace("le-cocon");
---

<BaseLayout
  title="Le Cocon - KerFlow Rituel"
  description="Le Cocon, espace KerFlow Rituel pour les massages, soins corporels, reflexologie, relaxation et recuperation a Clamart."
>
  <SiteHeader />
  <main class="cours-page cocon-page">
    <section class="cours-hero cocon-hero">
      <div class="cours-wrap">
        <div class="cours-hero-grid">
          <div>
            <p class="cours-kicker">KerFlow Rituel - Le Cocon</p>
            <h1>
              Le Cocon,<br />
              <em>relâcher</em><br />
              en douceur.
            </h1>
            <div class="cours-actions">
              <a href="/le-lieu/#le-cocon" class="btn btn-primary">Découvrir nos espaces <span aria-hidden="true">→</span></a>
              <a href="#intervenants" class="btn-line">Voir les intervenants</a>
            </div>
          </div>
          <aside class="cours-hero-aside">
            <img class="cours-hero-logo" src="/assets/logos/kerflow-rituel-web.png" alt="KerFlow Rituel" loading="eager" decoding="async" />
            <p>
              Des soins manuels pour prendre soin de son corps : massages bien-être, massage prénatal,
              drainage lymphatique manuel, fasciathérapie et autres pratiques proposées par nos praticiens.
            </p>
            <div class="cours-tags">
              <span>Détente</span><span>Apaisement</span><span>Récupération</span><span>Bien-être</span><span>Relaxation</span>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="cocon-section cocon-paperless" id="espace">
      <div class="cocon-wrap cocon-space-grid">
        <div>
          <h2>Le Cocon,<br />le lieu<br /><em>qui enveloppe.</em></h2>
          <p class="cocon-copy">
            Au sous-sol, un espace intimiste. Une atmosphère qui invite au lâcher-prise.
            Massages, réflexologie, soins du corps : le temps ralentit, on récupère.
          </p>
          <SiteVisual visual={siteVisuals.care.coconHero} class="cocon-placeholder" />
        </div>
        <aside>
          <p class="cocon-label">Pour quels besoins ?</p>
          <div class="cocon-list">
            <article>
              <span>01</span>
              <div>
                <h3>Détente & récupération</h3>
                <p>S'accorder un temps pour soi, relâcher les tensions et favoriser la récupération physique et mentale.</p>
                <div class="cocon-list-tags">
                  <span>Massage bien-être</span>
                  <span>Réflexologie</span>
                  <span>Relaxation</span>
                </div>
              </div>
            </article>
            <article>
              <span>02</span>
              <div>
                <h3>Confort corporel & mobilité</h3>
                <p>Prendre soin de son corps, améliorer sa mobilité et retrouver plus de confort au quotidien.</p>
                <div class="cocon-list-tags">
                  <span>Fasciathérapie</span>
                  <span>Shiatsu</span>
                  <span>Drainage lymphatique</span>
                </div>
              </div>
            </article>
            <article>
              <span>03</span>
              <div>
                <h3>Périnatalité & moments de transition</h3>
                <p>Des soins adaptés aux différentes étapes de la vie et aux besoins spécifiques de chacun.</p>
                <div class="cocon-list-tags">
                  <span>Massage prénatal</span>
                  <span>Réflexologie</span>
                  <span>Fasciathérapie</span>
                </div>
              </div>
            </article>
          </div>
        </aside>
      </div>
    </section>

    <section class="cocon-section cocon-paper" id="intervenants">
      <div class="cocon-wrap">
        <div class="cocon-head">
          <span>02 - Les intervenants</span>
          <h2>Les professionnel·les du Cocon,<br /><em>des mains expertes.</em></h2>
          <p>
            Des approches corporelles complémentaires, réunies pour leur sérieux,
            leur douceur et la qualité de leurs soins.
          </p>
        </div>
        <div class="cocon-brand-row">
          <img src="/assets/logos/kerflow-rituel-web.png" alt="KerFlow Rituel" loading="lazy" decoding="async" />
          <span>Au Cocon · soin corporel</span>
        </div>

        <div class="cocon-team">
          {practitioners.map((person) => (
            <article>
              <div class={`cocon-person-media cocon-${person.imageClass} ${person.visualMode === "image" && person.image ? "has-upload" : ""}`}>
                {person.visualMode === "image" && person.image ? (
                  <img src={person.image} alt={person.imageLabel} loading="lazy" decoding="async" />
                ) : (
                  <span>{person.imageLabel}</span>
                )}
              </div>
              <div>
                <h3>{person.name}</h3>
                <p class="cocon-role">{person.specialty}</p>
                <p>{person.bio}</p>
                <div>
                  <a href={person.primaryLinkUrl}>{person.primaryLinkLabel}</a>
                  <a href={person.secondaryLinkUrl}>{person.secondaryLinkLabel}</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="cocon-section cocon-paperless">
      <div class="cocon-wrap">
        <div class="cocon-head">
          <span>03 - Comment réserver</span>
          <h2>Un parcours simple,<br />en <em>trois temps.</em></h2>
        </div>
        <div class="cocon-steps">
          <article>
            <span>01</span>
            <h3>Vous choisissez</h3>
            <p>Découvrez les différents soins, puis choisissez le professionnel qui correspond le mieux à vos besoins.</p>
          </article>
          <article>
            <span>02</span>
            <h3>Vous prenez rendez-vous</h3>
            <p>Prenez directement contact avec le professionnel de votre choix pour convenir d'un rendez-vous.</p>
          </article>
          <article>
            <span>03</span>
            <h3>On vous accueille</h3>
            <p>Présentez-vous quelques minutes avant votre rendez-vous. Installez-vous confortablement à la tisanerie : on viendra vous chercher dès que possible.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="cocon-cta">
      <div class="cocon-wrap">
        <h2>Choisir un<br /><em>soin.</em></h2>
        <div>
          <p>
            Vous choisissez votre soin ou votre praticien·ne, vous prenez rendez-vous directement,
            et on vous accueille dans Le Cocon.
          </p>
          <div class="cours-actions">
            <a href="/le-lieu/#le-cocon" class="btn btn-light">Découvrir le lieu</a>
            <a href="#intervenants" class="btn-line on-dark">Voir les intervenants</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .cocon-page {
    --cours-accent: var(--clay);
    --cours-soft: var(--rituel);
    --cocon-accent: var(--clay);
    --cocon-soft: var(--rituel);
    --cocon-ink-soft: #545d57;
  }

  .cocon-page em {
    color: var(--cocon-accent);
  }

  .cocon-page .btn-primary {
    background: var(--cocon-accent);
  }

  .cocon-page .btn-primary:hover,
  .cocon-page .btn-primary:focus-visible {
    background: var(--clay);
    transform: translateY(-2px);
    box-shadow: 0 14px 26px rgba(14, 42, 44, 0.16);
  }

  .cocon-hero {
    background: var(--cocon-soft);
  }

  .cocon-wrap {
    width: min(100%, var(--site-max));
    margin-inline: auto;
    padding-inline: var(--site-pad-x);
  }

  .cocon-section {
    padding-block: var(--site-section-y);
    border-top: 1px solid var(--rule);
  }

  .cocon-paper {
    background: var(--paper);
  }

  .cocon-paperless {
    background: var(--linen);
  }

  .cocon-space-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(280px, 1fr);
    gap: clamp(32px, 5vw, 72px);
    align-items: start;
  }

  .cocon-lock {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 22px;
    color: var(--cocon-accent);
    font-family: var(--serif);
    font-size: 30px;
    line-height: 1;
  }

  .cocon-lock small,
  .cocon-label,
  .cocon-head span,
  .cocon-role,
  .cocon-team article a {
    color: var(--cocon-accent);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .cocon-lock small {
    font-size: 10px;
    letter-spacing: 0.26em;
  }

  .cocon-space-grid h2,
  .cocon-head h2,
  .cocon-cta h2 {
    margin: 0;
    color: var(--petrol-deep);
    font-family: var(--serif);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    letter-spacing: -0.026em;
  }

  .cocon-space-grid h2,
  .cocon-head h2 {
    margin-top: 12px;
    font-size: clamp(38px, 5vw, 72px);
    line-height: 1;
  }

  .cocon-copy,
  .cocon-head p {
    max-width: 560px;
    color: var(--cocon-ink-soft);
    font-size: 16.5px;
    line-height: 1.7;
  }

  .cocon-placeholder,
  .cocon-person-media {
    display: grid;
    place-items: center;
    color: rgba(14, 42, 44, 0.7);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    line-height: 1.5;
    text-align: center;
    text-transform: uppercase;
  }

  .cocon-placeholder {
    max-width: 480px;
    aspect-ratio: 4 / 3;
    margin-top: 30px;
    border: 12px solid var(--paper);
    padding: 22px;
  }

  .cocon-placeholder span,
  .cocon-person-media span {
    display: none;
  }

  .cocon-person-media {
    position: relative;
    overflow: hidden;
  }

  .cocon-person-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cocon-foam {
    background: linear-gradient(135deg, #ecd7c8, #faf0e7);
  }

  .cocon-storm {
    background: linear-gradient(135deg, #d99a78, #6b3d29);
  }

  .cocon-fern {
    background: linear-gradient(135deg, #c6d8bd, #708168);
  }

  .cocon-clay {
    background: linear-gradient(135deg, #d99a78, #ecd7c8);
  }

  .cocon-sand {
    background: linear-gradient(135deg, #f1ebe1, #d6d8d3);
  }

  .cocon-list {
    display: grid;
    margin-top: 18px;
    border-top: 1px solid rgba(160, 90, 58, 0.25);
  }

  .cocon-list article {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 24px;
    align-items: baseline;
    padding: 26px 0;
    border-bottom: 1px solid rgba(160, 90, 58, 0.25);
  }

  .cocon-list article > span,
  .cocon-steps article > span {
    color: var(--cocon-accent);
    font-family: var(--serif);
    font-size: 30px;
    font-style: italic;
    line-height: 1;
  }

  .cocon-list h3,
  .cocon-team h3,
  .cocon-steps h3 {
    margin: 0;
    color: var(--petrol-deep);
    font-family: var(--serif);
    font-size: clamp(22px, 2.2vw, 30px);
    font-weight: 400;
    line-height: 1.06;
  }

  .cocon-list p,
  .cocon-team article p,
  .cocon-steps p {
    margin: 0;
    color: var(--granite);
    font-size: 14px;
    line-height: 1.6;
  }

  .cocon-list-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 14px;
  }

  .cocon-list-tags span {
    border: 1px solid var(--cocon-accent);
    padding: 7px 12px;
    color: var(--cocon-accent);
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .cocon-head {
    max-width: 820px;
    margin-bottom: clamp(32px, 4vw, 52px);
  }

  .cocon-brand-row {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    align-items: center;
    margin: 0 0 clamp(28px, 4vw, 48px);
  }

  .cocon-brand-row img {
    width: min(180px, 54vw);
    height: auto;
  }

  .cocon-brand-row span {
    color: var(--cocon-accent);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .cocon-team {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(18px, 2vw, 28px);
  }

  .cocon-team article {
    border: 1px solid var(--rule);
    background: var(--paper);
  }

  .cocon-person-media {
    aspect-ratio: 16 / 9;
    padding: 20px;
  }

  .cocon-team article > div:last-child {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 22px;
  }

  .cocon-team article > div:last-child > div {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 8px;
    padding-top: 12px;
    border-top: 1px solid var(--rule-soft);
  }

  .cocon-team article a:hover,
  .cocon-team article a:focus-visible {
    color: var(--clay);
  }

  .cocon-steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--rule);
  }

  .cocon-steps article {
    display: flex;
    min-height: 210px;
    flex-direction: column;
    gap: 12px;
    padding: clamp(26px, 3vw, 36px);
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .cocon-steps article:last-child {
    border-right: 0;
  }

  .cocon-cta {
    padding-block: clamp(72px, 8vw, 104px);
    background: var(--cocon-accent);
    color: var(--linen);
  }

  .cocon-cta .cocon-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
  }

  .cocon-cta h2 {
    color: var(--linen);
    font-size: clamp(42px, 6vw, 86px);
    line-height: 0.96;
  }

  .cocon-cta em {
    color: var(--clay-light);
  }

  .cocon-cta p {
    max-width: 520px;
    margin: 0;
    color: rgba(241, 235, 225, 0.84);
    font-size: 17px;
    line-height: 1.7;
  }

  .cocon-cta .btn-light {
    background: var(--linen);
    color: var(--cocon-accent);
  }

  .cocon-cta .btn-light:hover,
  .cocon-cta .btn-light:focus-visible {
    background: var(--petrol-deep);
    color: var(--linen);
  }

  .cocon-cta .btn-line.on-dark {
    color: var(--linen);
  }

  .cocon-cta .btn-line.on-dark:hover,
  .cocon-cta .btn-line.on-dark:focus-visible {
    color: var(--clay-light);
  }

  @media (max-width: 900px) {
    .cocon-space-grid,
    .cocon-cta .cocon-wrap {
      grid-template-columns: 1fr;
    }

    .cocon-team,
    .cocon-steps {
      grid-template-columns: 1fr;
    }

    .cocon-steps article {
      border-right: 0;
    }
  }
</style>
