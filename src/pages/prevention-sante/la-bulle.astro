---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteVisual from "../../components/SiteVisual.astro";
import { peopleForSpace } from "../../data/cmsContent.js";
import { siteVisuals } from "../../data/siteVisuals.js";

const practitioners = peopleForSpace("la-bulle");
---

<BaseLayout
  title="La Bulle - KerFlow Consult"
  description="La Bulle, espace KerFlow Consult pour les accompagnements individuels, sommeil, alimentation, stress et comportements de sante a Clamart."
>
  <SiteHeader />
  <main class="cours-page bulle-page">
    <section class="cours-hero bulle-hero">
      <div class="cours-wrap">
        <div class="cours-hero-grid">
          <div>
            <p class="cours-kicker">KerFlow Consult - La Bulle</p>
            <h1>
              La Bulle,<br />
              <em>mieux se</em><br />
              comprendre.
            </h1>
            <div class="cours-actions">
              <a href="/le-lieu/#la-bulle" class="btn btn-primary">Découvrir nos espaces <span aria-hidden="true">→</span></a>
              <a href="#intervenants" class="btn-line">Voir les intervenants</a>
            </div>
          </div>
          <aside class="cours-hero-aside">
            <img class="cours-hero-logo" src="/assets/logos/kerflow-consult-web.png" alt="KerFlow Consult" loading="eager" decoding="async" />
            <p>
              Des consultations individuelles pour être accompagné sur des sujets liés à la prévention santé et au mieux-être :
              alimentation, sommeil, gestion du stress, équilibre de vie ou santé de la femme.
            </p>
            <div class="cours-tags">
              <span>Nutrition</span><span>Sommeil</span><span>Équilibre de vie</span><span>Vitalité</span><span>Émotions</span>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="bulle-section bulle-paperless" id="espace">
      <div class="bulle-wrap bulle-space-grid">
        <div>
          <h2>La Bulle,<br />le cabinet<br /><em>qui écoute.</em></h2>
          <p class="bulle-copy">
            Un bureau de consultation au rez-de-chaussée, baigné de lumière naturelle,
            une grande fenêtre ouverte sur une cour calme et arborée. Un cadre apaisant
            pour des accompagnements individuels.
          </p>
          <SiteVisual visual={siteVisuals.care.bulleHero} class="bulle-placeholder" />
        </div>
        <aside>
          <p class="bulle-label">Pour quels besoins ?</p>
          <div class="bulle-list">
            <article>
              <span>01</span>
              <div>
                <h3>Alimentation & hygiène de vie</h3>
                <p>Mieux comprendre ses habitudes, retrouver de l'énergie et construire des changements durables.</p>
              </div>
            </article>
            <article>
              <span>02</span>
              <div>
                <h3>Sommeil, stress & équilibre émotionnel</h3>
                <p>Retrouver un meilleur équilibre au quotidien et mieux comprendre les mécanismes qui influencent notre bien-être.</p>
              </div>
            </article>
            <article>
              <span>03</span>
              <div>
                <h3>Parcours de vie & transitions</h3>
                <p>Être accompagné lors d'une étape de vie, d'un changement ou d'un questionnement personnel.</p>
              </div>
            </article>
          </div>
          <div class="bulle-tags">
            <span>Napsothérapie · Diététique · Naturopathie</span>
            <span>Psychologie · Sophrologie · Hypnose</span>
            <span>Sexologie · Coaching de vie · Accompagnement périnatal</span>
          </div>
        </aside>
      </div>
    </section>

    <section class="bulle-section bulle-paper" id="intervenants">
      <div class="bulle-wrap">
        <div class="bulle-head">
          <span>02 - Les intervenants</span>
          <h2>Les professionnel·les de La Bulle,<br /><em>une écoute attentive.</em></h2>
          <p>
            Chaque praticien·ne possède sa propre spécialité et sa propre approche.
            Nous les avons choisi·es pour leur professionnalisme, leur expérience et leur sens de l'écoute.
          </p>
        </div>
        <div class="bulle-brand-row">
          <img src="/assets/logos/kerflow-consult-web.png" alt="KerFlow Consult" loading="lazy" decoding="async" />
          <span>À La Bulle · accompagnement</span>
        </div>

        <div class="bulle-team">
          {practitioners.map((person) => (
            <article>
              <div class={`bulle-person-media bulle-${person.imageClass} ${person.visualMode === "image" && person.image ? "has-upload" : ""}`}>
                {person.visualMode === "image" && person.image ? (
                  <img src={person.image} alt={person.imageLabel} loading="lazy" decoding="async" />
                ) : (
                  <span>{person.imageLabel}</span>
                )}
              </div>
              <div>
                <h3>{person.name}</h3>
                <p class="bulle-role">{person.specialty}</p>
                <p>{person.bio}</p>
                <div>
                  <a href={person.primaryLinkUrl}>{person.primaryLinkLabel}</a>
                  <a href={person.secondaryLinkUrl}>{person.secondaryLinkLabel}</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bulle-section bulle-paperless">
      <div class="bulle-wrap">
        <div class="bulle-head">
          <span>03 - Comment réserver</span>
          <h2>Un parcours simple,<br />en <em>trois temps.</em></h2>
        </div>
        <div class="bulle-steps">
          <article>
            <span>01</span>
            <h3>Vous choisissez</h3>
            <p>Découvrez les différents accompagnements, puis choisissez le professionnel qui correspond le mieux à vos besoins.</p>
          </article>
          <article>
            <span>02</span>
            <h3>Vous prenez rendez-vous</h3>
            <p>Prenez directement contact avec le professionnel de votre choix pour convenir d'un rendez-vous.</p>
          </article>
          <article>
            <span>03</span>
            <h3>On vous accueille</h3>
            <p>Présentez-vous quelques minutes avant votre rendez-vous. Installez-vous confortablement à la tisanerie : on viendra vous chercher dès que possible.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="bulle-cta">
      <div class="bulle-wrap">
        <h2>Choisir un<br /><em>accompagnement.</em></h2>
        <div>
          <p>
            Vous choisissez votre praticien·ne, vous prenez rendez-vous directement avec lui ou elle,
            et on vous accueille dans La Bulle.
          </p>
          <div class="cours-actions">
            <a href="/le-lieu/#la-bulle" class="btn btn-light">Découvrir le lieu</a>
            <a href="#intervenants" class="btn-line on-dark">Voir les intervenants</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .bulle-page {
    --cours-accent: #2f6a6c;
    --cours-soft: var(--sea-mist);
    --bulle-accent: #2f6a6c;
    --bulle-soft: var(--sea-mist);
    --bulle-ink-soft: #545d57;
  }

  .bulle-page em {
    color: var(--bulle-accent);
  }

  .bulle-page .btn-primary {
    background: var(--bulle-accent);
  }

  .bulle-page .btn-primary:hover,
  .bulle-page .btn-primary:focus-visible {
    background: var(--clay);
    transform: translateY(-2px);
    box-shadow: 0 14px 26px rgba(14, 42, 44, 0.16);
  }

  .bulle-hero {
    background: var(--bulle-soft);
  }

  .bulle-wrap {
    width: min(100%, var(--site-max));
    margin-inline: auto;
    padding-inline: var(--site-pad-x);
  }

  .bulle-section {
    padding-block: var(--site-section-y);
    border-top: 1px solid var(--rule);
  }

  .bulle-paper {
    background: var(--paper);
  }

  .bulle-paperless {
    background: var(--linen);
  }

  .bulle-space-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(280px, 1fr);
    gap: clamp(32px, 5vw, 72px);
    align-items: start;
  }

  .bulle-lock {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 22px;
    color: var(--bulle-accent);
    font-family: var(--serif);
    font-size: 30px;
    line-height: 1;
  }

  .bulle-lock small,
  .bulle-label,
  .bulle-head span,
  .bulle-role,
  .bulle-team article a {
    color: var(--bulle-accent);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .bulle-lock small {
    font-size: 10px;
    letter-spacing: 0.26em;
  }

  .bulle-space-grid h2,
  .bulle-head h2,
  .bulle-cta h2 {
    margin: 0;
    color: var(--petrol-deep);
    font-family: var(--serif);
    font-weight: 400;
    font-variation-settings: "opsz" 144;
    letter-spacing: -0.026em;
  }

  .bulle-space-grid h2,
  .bulle-head h2 {
    margin-top: 12px;
    font-size: clamp(38px, 5vw, 72px);
    line-height: 1;
  }

  .bulle-copy,
  .bulle-head p {
    max-width: 560px;
    color: var(--bulle-ink-soft);
    font-size: 16.5px;
    line-height: 1.7;
  }

  .bulle-placeholder,
  .bulle-person-media {
    display: grid;
    place-items: center;
    color: rgba(14, 42, 44, 0.7);
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    line-height: 1.5;
    text-align: center;
    text-transform: uppercase;
  }

  .bulle-placeholder {
    max-width: 480px;
    aspect-ratio: 4 / 3;
    margin-top: 30px;
    border: 12px solid var(--paper);
    padding: 22px;
  }

  .bulle-placeholder span,
  .bulle-person-media span {
    display: none;
  }

  .bulle-person-media {
    position: relative;
    overflow: hidden;
  }

  .bulle-person-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bulle-foam {
    background: linear-gradient(135deg, #dce9e5, #eef4ee);
  }

  .bulle-storm {
    background: linear-gradient(135deg, #c9dad7, #7e837b);
  }

  .bulle-fern {
    background: linear-gradient(135deg, #c6d8bd, #708168);
  }

  .bulle-clay {
    background: linear-gradient(135deg, #d99a78, #ecd7c8);
  }

  .bulle-sand {
    background: linear-gradient(135deg, #f1ebe1, #d6d8d3);
  }

  .bulle-list {
    display: grid;
    margin-top: 18px;
    border-top: 1px solid rgba(47, 106, 108, 0.25);
  }

  .bulle-list article {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 24px;
    align-items: baseline;
    padding: 26px 0;
    border-bottom: 1px solid rgba(47, 106, 108, 0.25);
  }

  .bulle-list article > span,
  .bulle-steps article > span {
    color: var(--bulle-accent);
    font-family: var(--serif);
    font-size: 30px;
    font-style: italic;
    line-height: 1;
  }

  .bulle-list h3,
  .bulle-team h3,
  .bulle-steps h3 {
    margin: 0;
    color: var(--petrol-deep);
    font-family: var(--serif);
    font-size: clamp(22px, 2.2vw, 30px);
    font-weight: 400;
    line-height: 1.06;
  }

  .bulle-list p,
  .bulle-team article p,
  .bulle-steps p {
    margin: 0;
    color: var(--granite);
    font-size: 14px;
    line-height: 1.6;
  }

  .bulle-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 24px;
  }

  .bulle-tags span {
    border: 1px solid var(--bulle-accent);
    padding: 7px 12px;
    color: var(--bulle-accent);
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .bulle-head {
    max-width: 820px;
    margin-bottom: clamp(32px, 4vw, 52px);
  }

  .bulle-brand-row {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    align-items: center;
    margin: 0 0 clamp(28px, 4vw, 48px);
  }

  .bulle-brand-row img {
    width: min(180px, 54vw);
    height: auto;
  }

  .bulle-brand-row span {
    color: var(--bulle-accent);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .bulle-team {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(18px, 2vw, 28px);
  }

  .bulle-team article {
    border: 1px solid var(--rule);
    background: var(--paper);
  }

  .bulle-person-media {
    aspect-ratio: 16 / 9;
    padding: 20px;
  }

  .bulle-team article > div:last-child {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 22px;
  }

  .bulle-team article > div:last-child > div {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 8px;
    padding-top: 12px;
    border-top: 1px solid var(--rule-soft);
  }

  .bulle-team article a:hover,
  .bulle-team article a:focus-visible {
    color: var(--clay);
  }

  .bulle-steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--rule);
  }

  .bulle-steps article {
    display: flex;
    min-height: 210px;
    flex-direction: column;
    gap: 12px;
    padding: clamp(26px, 3vw, 36px);
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .bulle-steps article:last-child {
    border-right: 0;
  }

  .bulle-cta {
    padding-block: clamp(72px, 8vw, 104px);
    background: var(--bulle-accent);
    color: var(--linen);
  }

  .bulle-cta .bulle-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
  }

  .bulle-cta h2 {
    color: var(--linen);
    font-size: clamp(42px, 6vw, 86px);
    line-height: 0.96;
  }

  .bulle-cta em {
    color: var(--sea-mist);
  }

  .bulle-cta p {
    max-width: 520px;
    margin: 0;
    color: rgba(241, 235, 225, 0.84);
    font-size: 17px;
    line-height: 1.7;
  }

  .bulle-cta .btn-light {
    background: var(--linen);
    color: var(--bulle-accent);
  }

  .bulle-cta .btn-light:hover,
  .bulle-cta .btn-light:focus-visible {
    background: var(--petrol-deep);
    color: var(--linen);
  }

  .bulle-cta .btn-line.on-dark {
    color: var(--linen);
  }

  .bulle-cta .btn-line.on-dark:hover,
  .bulle-cta .btn-line.on-dark:focus-visible {
    color: var(--sea-mist);
  }

  @media (max-width: 900px) {
    .bulle-space-grid,
    .bulle-cta .bulle-wrap {
      grid-template-columns: 1fr;
    }

    .bulle-team,
    .bulle-steps {
      grid-template-columns: 1fr;
    }

    .bulle-steps article {
      border-right: 0;
    }
  }
</style>
