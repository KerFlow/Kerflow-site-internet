<header class="site-header">
      <a class="brand" href="/" aria-label="KerFlow">
        <img class="brand-logo" src="/assets/logos/kerflow-solo-web.png" width="1200" height="226" alt="KerFlow" loading="eager" decoding="async" />
      </a>
      <nav class="main-nav" aria-label="Navigation principale">
        <a href="/le-lieu/">Le lieu</a>
        <a href="/cours-planning/">Cours & planning</a>
        <details class="nav-item has-submenu">
          <summary class="nav-trigger">Accompagnements & Soins</summary>
          <div class="nav-submenu" aria-label="Sous-navigation Accompagnements & Soins">
            <a href="/prevention-sante/">Accompagnements & Soins <span>Vue d'ensemble</span></a>
            <a href="/prevention-sante/la-bulle/">La Bulle <span>KerFlow Consult</span></a>
            <a href="/prevention-sante/le-cocon/">Le Cocon <span>KerFlow Rituel</span></a>
          </div>
        </details>
        <a href="/louer-un-espace/">Louer un espace</a>
        <a href="/ateliers-ressources/">Ateliers & ressources</a>
        <a href="/faq/">FAQ</a>
        <a href="/contact/">Contact</a>
      </nav>
      <div class="header-actions">
        <a class="reserve-link" href="/cours-planning/">Réserver</a>
        <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav" aria-label="Ouvrir le menu">
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
        </button>
      </div>
      <nav id="mobile-nav" class="mobile-nav" aria-label="Navigation mobile" hidden>
        <a href="/le-lieu/">Le lieu</a>
        <a href="/cours-planning/">Cours & planning</a>
        <a href="/prevention-sante/">Accompagnements & Soins</a>
        <a href="/prevention-sante/la-bulle/">La Bulle</a>
        <a href="/prevention-sante/le-cocon/">Le Cocon</a>
        <a href="/louer-un-espace/">Louer un espace</a>
        <a href="/ateliers-ressources/">Ateliers & ressources</a>
        <a href="/faq/">FAQ</a>
        <a href="/contact/">Contact</a>
      </nav>
    </header>

<script is:inline>
  (() => {
    const headers = document.querySelectorAll(".site-header");
    const hideAfter = 96;
    const scrollDelta = 8;

    headers.forEach((header) => {
      const button = header.querySelector(".menu-toggle");
      const nav = header.querySelector(".mobile-nav");
      const submenus = header.querySelectorAll(".has-submenu");
      let lastScrollY = window.scrollY;
      let ticking = false;

      if (!button || !nav) return;

      const closeSubmenus = () => {
        submenus.forEach((submenu) => {
          if (submenu instanceof HTMLDetailsElement) submenu.open = false;
          if (document.activeElement instanceof HTMLElement && submenu.contains(document.activeElement)) {
            document.activeElement.blur();
          }
        });
      };

      const closeSubmenu = (submenu) => {
        if (submenu instanceof HTMLDetailsElement) submenu.open = false;
        if (document.activeElement instanceof HTMLElement && submenu.contains(document.activeElement)) {
          document.activeElement.blur();
        }
      };

      const isPointerInsideSubmenuArea = (submenu, event) => {
        const submenuPanel = submenu.querySelector(".nav-submenu");
        const triggerRect = submenu.getBoundingClientRect();
        const panelRect = submenuPanel?.getBoundingClientRect();
        const padding = 16;
        const isInsideTrigger =
          event.clientX >= triggerRect.left - padding &&
          event.clientX <= triggerRect.right + padding &&
          event.clientY >= triggerRect.top - padding &&
          event.clientY <= triggerRect.bottom + padding;
        const isInsidePanel =
          panelRect &&
          event.clientX >= panelRect.left - padding &&
          event.clientX <= panelRect.right + padding &&
          event.clientY >= panelRect.top - padding &&
          event.clientY <= panelRect.bottom + padding;

        return isInsideTrigger || isInsidePanel;
      };

      const close = () => {
        button.setAttribute("aria-expanded", "false");
        button.setAttribute("aria-label", "Ouvrir le menu");
        nav.hidden = true;
        header.classList.remove("is-menu-open");
      };

      const open = () => {
        button.setAttribute("aria-expanded", "true");
        button.setAttribute("aria-label", "Fermer le menu");
        nav.hidden = false;
        header.classList.add("is-menu-open");
        header.classList.remove("is-hidden");
      };

      const updateHeaderVisibility = () => {
        const currentScrollY = Math.max(window.scrollY, 0);
        const isMenuOpen = header.classList.contains("is-menu-open");
        const isScrollingDown = currentScrollY > lastScrollY + scrollDelta;
        const isScrollingUp = currentScrollY < lastScrollY - scrollDelta;
        const hasHeaderFocus = document.activeElement instanceof HTMLElement && header.contains(document.activeElement);

        if (currentScrollY <= hideAfter || isMenuOpen || hasHeaderFocus) {
          header.classList.remove("is-hidden");
        } else if (isScrollingDown) {
          header.classList.add("is-hidden");
        } else if (isScrollingUp) {
          header.classList.remove("is-hidden");
        }

        if (Math.abs(currentScrollY - lastScrollY) >= scrollDelta) {
          lastScrollY = currentScrollY;
        }

        ticking = false;
      };

      const requestHeaderUpdate = () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(updateHeaderVisibility);
      };

      button.addEventListener("click", () => {
        const expanded = button.getAttribute("aria-expanded") === "true";
        expanded ? close() : open();
      });

      nav.addEventListener("click", (event) => {
        if (event.target instanceof HTMLAnchorElement) close();
      });

      submenus.forEach((submenu) => {
        submenu.addEventListener("mouseleave", () => {
          closeSubmenu(submenu);
        });

        submenu.addEventListener("focusout", (event) => {
          if (event.relatedTarget instanceof Node && submenu.contains(event.relatedTarget)) return;
          if (submenu instanceof HTMLDetailsElement) submenu.open = false;
        });

        submenu.addEventListener("click", (event) => {
          if (event.target instanceof HTMLAnchorElement && submenu instanceof HTMLDetailsElement) {
            submenu.open = false;
          }
        });
      });

      document.addEventListener("pointerdown", (event) => {
        if (event.target instanceof Node && header.contains(event.target)) return;
        closeSubmenus();
      });

      document.addEventListener("pointermove", (event) => {
        submenus.forEach((submenu) => {
          if (!(submenu instanceof HTMLDetailsElement) || !submenu.open) return;
          if (isPointerInsideSubmenuArea(submenu, event)) return;
          closeSubmenu(submenu);
        });
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          close();
          closeSubmenus();
        }
      });

      window.addEventListener("resize", () => {
        if (window.matchMedia("(min-width: 1181px)").matches) close();
        if (window.matchMedia("(max-width: 1180px)").matches) closeSubmenus();
        requestHeaderUpdate();
      });

      window.addEventListener("scroll", requestHeaderUpdate, { passive: true });
    });
  })();
</script>
