---
const mapsDirectionsUrl =
  "https://www.google.com/maps/dir/?api=1&destination=169%20avenue%20Jean%20Jaures%2C%2092140%20Clamart";
---

<div class="map-card">
  <div class="map-illustration">
    <svg viewBox="0 0 400 280" aria-label="Carte illustrée entre la gare de Clamart et KerFlow">
      <path d="M-20 80C80 60 160 100 220 80C300 60 380 100 420 80"></path>
      <path d="M-20 160C60 180 140 140 220 170C300 195 360 170 420 180"></path>
      <path d="M80-10C100 60 90 140 130 220C140 250 130 280 140 300"></path>
      <path d="M240-10C260 80 230 160 270 240C280 270 285 290 280 310"></path>
      <path class="rail" d="M0 230C80 240 200 220 400 250"></path>
      <rect x="158" y="210" width="44" height="20"></rect>
      <text x="180" y="262">GARE DE CLAMART</text>
      <circle class="pin" cx="260" cy="100" r="6"></circle>
      <circle class="pin-ring" cx="260" cy="100" r="14"></circle>
      <text class="label" x="280" y="104">KerFlow</text>
      <text x="280" y="122">169 AVENUE JEAN JAURES</text>
      <path class="walk" d="M180 215C200 180 230 140 256 105"></path>
    </svg>
    <div class="map-caption mono"><span>Clamart - 92140</span><span>7 min à pied de la gare</span></div>
  </div>
  <footer>
    <span>Voir l'itinéraire</span>
    <a class="btn-line" href={mapsDirectionsUrl} target="_blank" rel="noreferrer">Ouvrir Google Maps</a>
  </footer>
</div>
