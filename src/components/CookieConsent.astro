<div class="cookie-consent" data-cookie-consent hidden>
  <div class="cookie-consent__copy">
    <p class="cookie-consent__title">Gestion des cookies</p>
    <p>
      KerFlow utilise uniquement les cookies nécessaires au bon fonctionnement du site.
      Les cookies de mesure ou de services externes ne sont activés qu'avec votre accord.
    </p>
  </div>
  <div class="cookie-consent__actions" aria-label="Choix de consentement cookies">
    <button class="btn-line cookie-consent__button" type="button" data-cookie-choice="refused">Refuser</button>
    <button class="btn btn-primary cookie-consent__button" type="button" data-cookie-choice="accepted">Accepter</button>
  </div>
</div>
