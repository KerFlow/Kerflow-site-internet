---
import SiteVisual from "../SiteVisual.astro";
import { siteVisuals } from "../../data/siteVisuals.js";
---

<section class="hero section-pad">
        <div class="hero-meta mono">
          <span>Clamart - 92140 - Île-de-France</span>
          <span>Ouverture prochaine - automne 26</span>
        </div>
        <div class="hero-grid">
          <div>
            <h1>Une maison<br>pour <em>bouger,</em><br><em>respirer,</em> revenir<br>à soi.</h1>
            <div class="actions hero-actions">
              <a class="btn btn-primary" href="#planning">Réserver un cours <span aria-hidden="true">→</span></a>
              <a class="btn-line" href="#lieu">Découvrir le lieu</a>
            </div>
          </div>
          <aside class="hero-intro">
            <p>KerFlow est une maison d'<em>accompagnements & soins</em> et de mieux-être à Clamart. On vient bouger, mieux dormir, mieux manger, sans pression, sans injonction, à taille humaine.</p>
            <div class="chips" aria-label="Disciplines">
              <span>Yoga</span>
              <span>Pilates</span>
              <span>Mobilité</span>
              <span>Respiration</span>
              <span>Soins</span>
              <span>Consultations</span>
            </div>
          </aside>
        </div>
      </section>

      <section class="home-gallery-section" aria-label="Galerie du lieu">
        <div class="gallery">
          <div class="gallery-head">
            <span class="gallery-eyebrow">↘ Matière, lumière, mouvement</span>
            <span class="gallery-label mono">La maison en images</span>
          </div>
          <div class="gallery-track-mask">
            <div class="gallery-track">
              {siteVisuals.homeGallery.map((visual) => <SiteVisual visual={visual} />)}
              {siteVisuals.homeGallery.map((visual) => <SiteVisual visual={visual} ariaHidden />)}
            </div>
          </div>
        </div>
      </section>
