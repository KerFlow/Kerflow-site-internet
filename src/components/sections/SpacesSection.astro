---
import SiteVisual from "../SiteVisual.astro";
import { siteVisuals } from "../../data/siteVisuals.js";
---

<section id="espaces" class="spaces section-pad deep">
        <div class="section-head split">
          <div>
            <p class="eyebrow">04 - Trois espaces, sous un même toit</p>
            <h2>La maison <em>respire</em> en trois temps.</h2>
          </div>
          <a class="btn-line light" href="#contact">Visiter le lieu</a>
        </div>
        <div class="space-grid">
          <article>
            <SiteVisual visual={siteVisuals.homeSpaces.studio} class="photo" />
            <div>
              <p class="mini">01 - Cours collectifs</p>
              <h3>La Salle de pratique</h3>
              <p>Une grande pièce en bois clair, deux fenêtres ouvertes sur le jardin. Cours collectifs en petits groupes: yoga, Pilates, mobilité.</p>
              <footer><span>10 places max</span><a href="#planning">Voir →</a></footer>
            </div>
          </article>
          <article>
            <SiteVisual visual={siteVisuals.homeSpaces.bulle} class="photo" />
            <div>
              <p class="mini">02 - Accompagnements & Soins</p>
              <h3>La Bulle</h3>
              <p>Cabinet de consultation lumineux. NAPSOthérapie, nutrition, sommeil, accompagnement individuel.</p>
              <footer><span>Consultations - 1h</span><a href="#soins">Voir →</a></footer>
            </div>
          </article>
          <article>
            <SiteVisual visual={siteVisuals.homeSpaces.cocon} class="photo" />
            <div>
              <p class="mini">03 - Soins du corps</p>
              <h3>Le Cocon</h3>
              <p>Pièce feutrée pour les soins du corps. Massages, drainage lymphatique, réflexologie, soins corporels.</p>
              <footer><span>Soins - 45 à 90 min</span><a href="#soins">Voir →</a></footer>
            </div>
          </article>
        </div>
      </section>
