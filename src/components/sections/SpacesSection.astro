---
import SiteVisual from "../SiteVisual.astro";
import { siteVisuals } from "../../data/siteVisuals.js";
---

<section id="espaces" class="spaces section-pad deep">
        <div class="section-head split">
          <div>
            <p class="eyebrow">04 - Trois espaces, sous un même toit</p>
            <h2>Entrez, on vous fait <em>visiter</em></h2>
          </div>
          <a class="btn-line light" href="#contact">Visiter le lieu</a>
        </div>
        <div class="space-grid">
          <article>
            <SiteVisual visual={siteVisuals.homeSpaces.studio} class="photo" />
            <div>
              <p class="mini">01 - Cours collectifs</p>
              <h3>Le Salon</h3>
              <p>Une grande pièce lumineuse, des cours collectifs en petits groupes.</p>
              <footer><span>jusqu'à 12 tapis</span><a href="#planning">Voir →</a></footer>
            </div>
          </article>
          <article>
            <SiteVisual visual={siteVisuals.homeSpaces.bulle} class="photo" />
            <div>
              <p class="mini">02 - Accompagnements</p>
              <h3>La Bulle</h3>
              <p>Un lieu d'écoute, calme et confidentiel, pour faire le point.</p>
              <footer><span>RDV individuels</span><a href="#soins">Voir →</a></footer>
            </div>
          </article>
          <article>
            <SiteVisual visual={siteVisuals.homeSpaces.cocon} class="photo" />
            <div>
              <p class="mini">03 - Soins du corps</p>
              <h3>Le Cocon</h3>
              <p>Un lieu calme et enveloppant pour ralentir, récupérer et prendre soin de son corps.</p>
              <footer><span>Soins à la carte</span><a href="#soins">Voir →</a></footer>
            </div>
          </article>
        </div>
      </section>
