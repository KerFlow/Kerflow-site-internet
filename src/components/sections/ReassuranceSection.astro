---
import { homeTestimonials } from "../../data/cmsContent.js";
---

<section class="reassurance section-pad">
        <div class="testimonial-grid">
          <div class="testimonial-intro">
            <p class="eyebrow">08 - Avis</p>
            <h2>Les élèves<br><em>s'expriment</em></h2>
          </div>
          <div class="testimonial-list">
            {homeTestimonials.map((testimonial, index) => (
              <figure class:list={["testimonial-card", index === 0 && "testimonial-card-feature"]}>
                <div class="stars" aria-label="5 etoiles">★★★★★</div>
                <blockquote>{testimonial.quote}</blockquote>
                <figcaption><span>{testimonial.author}</span><span>{testimonial.context}</span></figcaption>
              </figure>
            ))}
          </div>
        </div>
        <div class="partners">
          <span class="mono">Une équipe qualifiée</span>
          <div class="qualification-copy">
            <p>Nos équipes réunissent notamment :</p>
            <ul>
              <li>Professeurs certifiés Yoga Alliance</li>
              <li>Enseignants formés à la méthode De Gasquet®</li>
              <li>Instructeurs Pilates FPMP</li>
              <li>Coachs en Activité Physique Adaptée (APA)</li>
            </ul>
          </div>
        </div>
      </section>
