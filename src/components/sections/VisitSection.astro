---
import KerflowMapCard from "../KerflowMapCard.astro";
import { siteSettings } from "../../data/cmsContent.js";

const showPhone = Boolean(siteSettings.phoneVisible && siteSettings.phoneDisplay);
const phoneHref = siteSettings.phoneHref ? `tel:${siteSettings.phoneHref}` : null;
---

<section id="contact" class="visit section-pad">
        <div class="visit-grid">
          <div>
            <p class="eyebrow">11 - Venir chez KerFlow</p>
            <h2>Au coeur du quartier<br><em>Gare de Clamart</em></h2>
            <div class="info-list">
              <div><span>Adresse</span><p>169 avenue Jean Jaures<br>92140 Clamart</p></div>
              <div><span>Accès</span><p>Bus 189 - Arrêt Lazare Carnot<br>Transilien N - Clamart (7 min à pied)</p></div>
              <div><span>Contact</span><p>kerflow.clamart@gmail.com</p></div>
              {showPhone && (
                <div>
                  <span>Téléphone</span>
                  <p>{phoneHref ? <a href={phoneHref}>{siteSettings.phoneDisplay}</a> : siteSettings.phoneDisplay}</p>
                </div>
              )}
            </div>
          </div>
          <KerflowMapCard />
        </div>
      </section>
