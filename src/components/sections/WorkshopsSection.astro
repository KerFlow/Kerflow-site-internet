---
import { blogSettings, workshops } from "../../data/cmsContent.js";
import { featuredBlogArticles } from "../../data/blogArticles.js";

const featuredArticle =
  featuredBlogArticles.find((article) => article.slug === blogSettings.featuredArticleSlug) ??
  featuredBlogArticles[0];
---

<section id="ateliers" class="workshops section-pad">
        <div class="section-head split">
          <div>
            <p class="eyebrow">07 - Ateliers du mois</p>
            <h2>Des rendez-vous pour <em>approfondir</em>, pratiquer autrement.</h2>
          </div>
          <a class="btn-line" href="#planning">Voir le calendrier complet</a>
        </div>

        <div class="workshop-grid" aria-label="Ateliers du mois">
          {workshops.map((workshop) => (
            <article class="workshop-card">
              <div class={`photo ${workshop.imageClass}`}><span>{workshop.imageLabel}</span></div>
              <div>
                <p class="mini clay">{workshop.date} - {workshop.time}</p>
                <h3>{workshop.title}</h3>
                <p>{workshop.description}</p>
                <footer><span>{workshop.duration} - {workshop.price}</span><a href={workshop.ctaUrl}>{workshop.ctaLabel} →</a></footer>
              </div>
            </article>
          ))}
        </div>

        <article class="editorial-feature" aria-label="Contenu éditorial mis en avant">
          <div class={`photo ${featuredArticle.imageClass} ${featuredArticle.visualMode === "image" && featuredArticle.image ? "has-upload" : ""}`}>
            {featuredArticle.visualMode === "image" && featuredArticle.image ? (
              <img src={featuredArticle.image} alt={featuredArticle.imageLabel} loading="lazy" decoding="async" />
            ) : (
              <span>{featuredArticle.imageLabel}</span>
            )}
          </div>
          <div class="editorial-copy">
            <p class="eyebrow">Article du moment</p>
            <h3>{featuredArticle.title}</h3>
            <p>{featuredArticle.excerpt}</p>
            <a class="btn-line" href={`/blog/${featuredArticle.slug}/`}>Lire l'article</a>
          </div>
        </article>
      </section>
