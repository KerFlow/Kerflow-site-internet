---
import SiteVisual from "../SiteVisual.astro";
import { siteVisuals } from "../../data/siteVisuals.js";
---

<section id="soins" class="offers section-pad alt">
        <div class="section-head narrow">
          <p class="eyebrow">06 - Au-delà des cours</p>
          <h2><em>Accompagnements</em><br>& soins.</h2>
        </div>
        <div class="offer-grid">
          <article>
            <div class="offer-copy">
              <p class="mini clay">La Bulle</p>
              <h3>Accompagnements<br>& soins</h3>
              <p>Consultations individuelles autour de l'alimentation, du sommeil, du stress, de l'activité physique et du bien-être mental. NAPSOthérapie et approche intégrative.</p>
              <a class="btn-line" href="#contact">Prendre rendez-vous</a>
            </div>
            <SiteVisual visual={siteVisuals.homeOffers.bulle} class="photo" />
          </article>
          <article>
            <div class="offer-copy">
              <p class="mini clay">Le Cocon</p>
              <h3>Soins du corps,<br>massages, réflexologie</h3>
              <p>Massages, drainage lymphatique, acupuncture, réflexologie, soins corporels. Une heure pour ralentir le rythme et déposer la semaine, pratique par des thérapeutes diplômés.</p>
              <a class="btn-line" href="#contact">Choisir un soin</a>
            </div>
            <SiteVisual visual={siteVisuals.homeOffers.cocon} class="photo" />
          </article>
        </div>
      </section>
